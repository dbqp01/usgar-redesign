---
import { Image } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';
import logoLight from '../assets/logos/Logo usgar morado.png';
import logoDark from '../assets/logos/Logo usgar.png';
import { useTranslations, type Locale } from '../i18n/utils';

const lang = (Astro.currentLocale || 'en') as Locale;
const t = useTranslations(lang);

const currentPath = Astro.url.pathname;
const searchParams = Astro.url.search;

const locales: { code: Locale; label: string; flag: string }[] = [
  { code: 'en', label: 'English', flag: '🇺🇸' },
  { code: 'es', label: 'Español', flag: '🇪🇸' },
  { code: 'fr', label: 'Français', flag: '🇫🇷' },
  { code: 'pt', label: 'Português', flag: '🇵🇹' }
];

function getLocaleUrl(targetLang: Locale): string {
  let cleanPath = currentPath.replace(/^\/(es|fr|pt)(\/|$)/, '/');
  if (!cleanPath.startsWith('/')) cleanPath = '/' + cleanPath;
  if (targetLang === 'en') {
    return cleanPath + searchParams;
  }
  return `/${targetLang}${cleanPath === '/' ? '' : cleanPath}${searchParams}`;
}

const homeUrl = getRelativeLocaleUrl(lang, '');
const cleanHomeUrl = homeUrl.endsWith('/') ? homeUrl : `${homeUrl}/`;

const navLinks = [
  { href: getRelativeLocaleUrl(lang, 'rooms'), label: t('nav.rooms') },
  { href: `${cleanHomeUrl}#services`, label: t('nav.services') },
  { href: getRelativeLocaleUrl(lang, 'explore'), label: t('nav.explore') },
  { href: getRelativeLocaleUrl(lang, 'gallery'), label: t('nav.gallery') },
  { href: getRelativeLocaleUrl(lang, 'contact'), label: t('nav.contact') },
];
---

<header
  id="main-navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href={getRelativeLocaleUrl(lang, '')} class="flex-shrink-0 relative z-10" aria-label="USGAR Hotels Home">
        <Image
          src={logoLight}
          alt="USGAR Hotels"
          width={120}
          class="h-10 w-auto hidden dark:block"
          loading="eager"
        />
        <Image
          src={logoDark}
          alt="USGAR Hotels"
          width={120}
          class="h-10 w-auto block dark:hidden"
          loading="eager"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'nav-link nav-link-text text-sm font-medium tracking-wide uppercase transition-colors duration-300 drop-shadow-md',
              currentPath === link.href ? 'text-primary' : 'text-white'
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right Side: Language, Theme, CTA -->
      <div class="hidden lg:flex items-center gap-4">
        <!-- Language Switcher Dropdown -->
        <div class="relative group">
          <button
            type="button"
            class="nav-link nav-link-text nav-btn-border text-white text-sm font-medium px-3 py-1.5 rounded-full border border-current/20 hover:border-primary hover:text-primary transition-all duration-300 drop-shadow-md flex items-center gap-1.5"
            aria-label="Select language"
          >
            <span>{locales.find(l => l.code === lang)?.flag}</span>
            <span>{lang.toUpperCase()}</span>
            <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <div class="absolute right-0 mt-2 w-40 rounded-2xl bg-surface-card-light dark:bg-surface-card-dark shadow-2xl border border-black/10 dark:border-white/10 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 py-2">
            {locales.map(l => (
              <a
                href={getLocaleUrl(l.code)}
                class:list={[
                  'flex items-center gap-3 px-4 py-2 text-sm font-medium transition-colors',
                  l.code === lang ? 'text-primary bg-primary/10' : 'text-text-primary-light dark:text-text-primary-dark hover:bg-black/5 dark:hover:bg-white/5'
                ]}
              >
                <span>{l.flag}</span>
                <span>{l.label}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Dark/Light Mode Toggle -->
        <button
          id="theme-toggle"
          class="nav-link nav-link-text relative w-10 h-10 rounded-full flex items-center justify-center hover:bg-black/5 dark:hover:bg-white/10 transition-colors duration-300 drop-shadow-md text-white"
          aria-label="Toggle dark mode"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <!-- Auth State (Sign In / User Avatar) -->
        <div id="auth-nav-desktop" class="flex items-center gap-3">
          <a
            href={getRelativeLocaleUrl(lang, 'login')}
            class="nav-link nav-link-text nav-btn-border text-white text-sm font-medium px-4 py-2 rounded-full border border-current/20 hover:border-primary hover:text-primary transition-all duration-300 drop-shadow-md"
          >
            {t('auth.signIn')}
          </a>
        </div>

        <!-- CTA: Book Now -->
        <a
          href={getRelativeLocaleUrl(lang, 'book')}
          data-astro-prefetch="tap"
          class="bg-primary hover:bg-primary-dark text-white font-semibold text-sm px-6 py-2.5 rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-primary/25 hover:-translate-y-0.5"
        >
          {t('nav.bookNow')}
        </a>
      </div>

      <!-- Mobile: Theme + Hamburger -->
      <div class="flex lg:hidden items-center gap-2">
        <button
          id="theme-toggle-mobile"
          class="nav-link nav-link-text w-10 h-10 rounded-full flex items-center justify-center hover:bg-black/5 dark:hover:bg-white/10 transition-colors duration-300 drop-shadow-md text-white"
          aria-label="Toggle dark mode"
        >
          <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <button
          id="mobile-menu-btn"
          class="nav-link nav-link-text w-10 h-10 rounded-full flex items-center justify-center hover:bg-black/5 dark:hover:bg-white/10 transition-colors duration-300 drop-shadow-md text-white"
          aria-label="Open menu"
        >
          <svg class="w-6 h-6" id="hamburger-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-6 h-6 hidden" id="close-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu (slide-in) -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 hidden lg:hidden"
  >
    <!-- Backdrop -->
    <div id="mobile-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>

    <!-- Panel -->
    <div
      id="mobile-panel"
      class="absolute right-0 top-0 h-full w-80 max-w-[85vw] bg-surface-card-light dark:bg-surface-card-dark shadow-2xl translate-x-full transition-transform duration-300 ease-out"
    >
      <div class="flex flex-col h-full pt-24 pb-8 px-6">
        <!-- Nav Links -->
        <nav class="flex flex-col gap-1">
          {navLinks.map(link => (
            <a
              href={link.href}
              class="text-lg font-medium py-3 px-4 rounded-xl hover:bg-primary/10 hover:text-primary transition-all duration-200"
            >
              {link.label}
            </a>
          ))}
        </nav>

        <div class="border-t border-black/10 dark:border-white/10 my-6"></div>

        <!-- Language Switcher Mobile Grid -->
        <div class="flex flex-col gap-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-text-secondary-light dark:text-text-secondary-dark px-4">Language</span>
          <div class="grid grid-cols-2 gap-2">
            {locales.map(l => (
              <a
                href={getLocaleUrl(l.code)}
                class:list={[
                  'flex items-center gap-2 p-3 rounded-xl border text-sm font-medium transition-all',
                  l.code === lang ? 'border-primary bg-primary/10 text-primary' : 'border-black/10 dark:border-white/10 hover:bg-black/5 dark:hover:bg-white/5'
                ]}
              >
                <span>{l.flag}</span>
                <span>{l.label}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Spacer -->
        <div class="flex-1"></div>

        <!-- CTA -->
        <a
          href={getRelativeLocaleUrl(lang, 'book')}
          data-astro-prefetch="tap"
          class="bg-primary hover:bg-primary-dark text-white font-semibold text-center py-4 rounded-2xl transition-all duration-300 text-lg"
        >
          {t('nav.bookNow')}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  let abortController = new AbortController();

  function initNavbar() {
    abortController.abort();
    abortController = new AbortController();
    const signal = abortController.signal;

    const navbar = document.getElementById('main-navbar');
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileBackdrop = document.getElementById('mobile-backdrop');
    const mobilePanel = document.getElementById('mobile-panel');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');

    if (!navbar) return;

    let ticking = false;

    function handleScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          const path = window.location.pathname.replace(/\/$/, '') || '/';
          const isHome = path === '' || path === '/' || path === '/es' || path === '/fr' || path === '/pt';

          if (scrollY > 40 || !isHome) {
            navbar?.classList.add('glass', 'shadow-sm', 'navbar-scrolled');
          } else {
            navbar?.classList.remove('glass', 'shadow-sm', 'navbar-scrolled');
          }
          ticking = false;
        });
        ticking = true;
      }
    }
    
    window.addEventListener('scroll', handleScroll, { passive: true, signal });
    handleScroll();

    let isMenuOpen = false;

    function openMenu() {
      if (!mobileMenu || !mobileBackdrop || !mobilePanel || !hamburgerIcon || !closeIcon) return;
      isMenuOpen = true;
      mobileMenu.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        mobileBackdrop.classList.remove('opacity-0');
        mobileBackdrop.classList.add('opacity-100');
        mobilePanel.classList.remove('translate-x-full');
        mobilePanel.classList.add('translate-x-0');
      });
      hamburgerIcon.classList.add('hidden');
      closeIcon.classList.remove('hidden');
    }

    function closeMenu() {
      if (!mobileMenu || !mobileBackdrop || !mobilePanel || !hamburgerIcon || !closeIcon) return;
      isMenuOpen = false;
      mobileBackdrop.classList.remove('opacity-100');
      mobileBackdrop.classList.add('opacity-0');
      mobilePanel.classList.remove('translate-x-0');
      mobilePanel.classList.add('translate-x-full');
      hamburgerIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
      document.body.style.overflow = '';
      setTimeout(() => {
        if (!isMenuOpen) mobileMenu.classList.add('hidden');
      }, 300);
    }

    mobileMenuBtn?.addEventListener('click', () => {
      isMenuOpen ? closeMenu() : openMenu();
    }, { signal });

    mobileBackdrop?.addEventListener('click', closeMenu, { signal });

    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu, { signal });
    });

    function toggleTheme() {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    }

    document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme, { signal });
    document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme, { signal });
  }

  initNavbar();
  document.addEventListener('astro:page-load', initNavbar);
</script>
