---
import type { ComponentProps } from "astro/types";
import SVGIcons from "../icons/SVGIcons.astro";
import { useTranslations } from "../../i18n/utils";
import type { Locale } from "../../i18n/utils";

type IconName = ComponentProps<typeof SVGIcons>["name"];

interface AmenityItem {
  label: Record<string, string>;
  iconName: IconName;
}

interface Props {
  amenitiesMap: Record<string, AmenityItem>;
  lang: Locale;
}

const { amenitiesMap, lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="grid grid-cols-2 md:grid-cols-3 gap-4" id="room-amenities-grid">
  {
    Object.values(amenitiesMap).map((amenity) => (
      <div class="flex items-start gap-4 p-4 rounded-xl bg-surface-card-light dark:bg-surface-card-dark border border-black/5 dark:border-white/5 shadow-sm">
        <div class="p-2.5 rounded-lg bg-[#2DB5A0]/10 dark:bg-[#2DB5A0]/15 flex items-center justify-center">
          <SVGIcons name={amenity.iconName} class="w-5 h-5 text-tertiary" />
        </div>
        <div>
          <h3 class="font-medium text-sm text-text-primary-light dark:text-text-primary-dark">
            {amenity.label[lang] || amenity.label.en || amenity.label.es}
          </h3>
          <p class="text-xs text-text-secondary-light dark:text-text-secondary-dark mt-0.5">
            {t('global.includedFree')}
          </p>
        </div>
      </div>
    ))
  }
</div>
