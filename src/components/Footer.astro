---
import { Image } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';
import logo from '../assets/logos/Logo usgar morado.png';
import { useTranslations } from '../i18n/utils';
import { siteSettings } from '../data/settings';

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();

const homeUrl = getRelativeLocaleUrl(lang, '');
const cleanHomeUrl = homeUrl.endsWith('/') ? homeUrl : `${homeUrl}/`;

const quickLinks = [
  { href: cleanHomeUrl, label: t('nav.home') },
  { href: getRelativeLocaleUrl(lang, 'rooms'), label: t('nav.rooms') },
  { href: getRelativeLocaleUrl(lang, 'gallery'), label: t('nav.gallery') },
  { href: `${cleanHomeUrl}#services`, label: t('nav.services') },
  { href: getRelativeLocaleUrl(lang, 'explore'), label: t('nav.explore') },
  { href: getRelativeLocaleUrl(lang, 'book'), label: t('nav.bookNow') },
];

const socialLinks = siteSettings.socialLinks.map(s => ({
  href: s.url,
  label: s.label,
  icon: s.platform,
}));
---

<footer class="bg-surface-card-dark dark:bg-surface-dark text-text-primary-dark pt-16 pb-8" id="contact">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <div class="flex justify-center mb-12">
      <a href={getRelativeLocaleUrl(lang, '')} aria-label="USGAR Hotels Home">
        <Image
          src={logo}
          alt="USGAR Hotels"
          width={144}
          class="h-12 w-auto opacity-90 hover:opacity-100 transition-opacity"
        />
      </a>
    </div>

    <!-- 3-Column Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8 mb-12">
      <!-- Contact -->
      <div class="text-center md:text-left">
        <h3 class="font-display text-lg mb-4 text-secondary">{t('footer.contact')}</h3>
        <address class="not-italic space-y-3 text-sm text-text-secondary-dark">
          <p class="flex items-start justify-center md:justify-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{siteSettings.address[lang]}</span>
          </p>
          <p class="flex items-center justify-center md:justify-start gap-2">
            <svg class="w-4 h-4 flex-shrink-0 text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${siteSettings.email}`} class="hover:text-secondary transition-colors">{siteSettings.email}</a>
          </p>
          <p class="flex items-center justify-center md:justify-start gap-2">
            <svg class="w-4 h-4 flex-shrink-0 text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:+${siteSettings.phoneRaw}`} class="hover:text-secondary transition-colors">{siteSettings.phone}</a>
          </p>
        </address>
      </div>

      <!-- Quick Links -->
      <div class="text-center">
        <h3 class="font-display text-lg mb-4 text-secondary">{t('footer.quickLinks')}</h3>
        <nav class="space-y-2">
          {quickLinks.map(link => (
            <a
              href={link.href}
              class="block text-sm text-text-secondary-dark hover:text-secondary transition-colors duration-200"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Social Media -->
      <div class="text-center md:text-right">
        <h3 class="font-display text-lg mb-4 text-secondary">{t('footer.followUs')}</h3>
        <div class="flex justify-center md:justify-end gap-4 mb-6">
          {socialLinks.map(social => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-primary/20 hover:text-primary transition-all duration-300 hover:-translate-y-0.5"
              aria-label={social.label}
            >
              {social.icon === 'instagram' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              )}
              {social.icon === 'facebook' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              )}
              {social.icon === 'tripadvisor' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12.006 4.295c-2.67 0-5.338.784-7.645 2.353H0l1.963 2.135a5.997 5.997 0 004.04 10.43 5.976 5.976 0 004.075-1.6L12 19.705l1.922-2.09a5.972 5.972 0 004.075 1.6 5.997 5.997 0 004.04-10.43L24 6.648h-4.35a13.573 13.573 0 00-7.644-2.353zM12 6.76c1.874 0 3.727.56 5.295 1.587H6.706A11.115 11.115 0 0112 6.76zM5.997 17.213a3.997 3.997 0 110-7.994 3.997 3.997 0 010 7.994zm12.006 0a3.997 3.997 0 110-7.994 3.997 3.997 0 010 7.994zM5.997 11.219a2.0 2.0 0 100 4.0 2.0 2.0 0 000-4.0zm12.006 0a2.0 2.0 0 100 4.0 2.0 2.0 0 000-4.0z"/>
                </svg>
              )}
              {social.icon === 'booking' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M2.273 0v24h7.619c6.727 0 9.836-3.552 9.836-7.552 0-2.87-1.552-5.292-4.162-6.275v-.076c2.041-1.066 3.234-2.987 3.234-5.262C18.8 1.55 16.127 0 10.545 0H2.273zm4.5 3.6h3.22c2.652 0 4.108.869 4.108 2.87 0 2.152-1.607 3.145-4.108 3.145H6.773V3.6zm0 9.615h3.524c2.955 0 4.869.945 4.869 3.372 0 2.393-1.914 3.413-4.538 3.413H6.773v-6.785z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
        <p class="text-xs text-text-secondary-dark">
          {t('footer.findUs')}
        </p>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-white/10 pt-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs text-text-secondary-dark">
          &copy; {currentYear} USGAR Hotels. {t('footer.rights')}
        </p>
        <p class="text-xs text-text-secondary-dark">
          {t('footer.madeWith')}
        </p>
      </div>
    </div>
  </div>
</footer>
