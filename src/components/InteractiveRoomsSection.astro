---
import { Image } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { rooms } from '../data/rooms';
import { useTranslations } from '../i18n/utils';
import { translateBeds } from '../utils/helpers';

import type { Locale } from '../i18n/utils';

const lang = (Astro.currentLocale || 'en') as Locale;

const t = useTranslations(lang);

// Dynamically import first photo of each room
const allImages = import.meta.glob<{ default: ImageMetadata }>('../assets/rooms/**/*.jpg');
const defaultFallback = import.meta.glob<{ default: ImageMetadata }>('../assets/hotel/fallback-room-pasillo.jpg');

const roomsWithPhotos = await Promise.all(
  rooms.map(async (room) => {
    const roomImages = Object.entries(allImages)
      .filter(([path]) => path.includes(`/${room.photoFolder}/`))
      .sort(([a], [b]) => a.localeCompare(b));
    
    let img = null;
    if (roomImages.length > 0) {
      img = (await roomImages[0][1]()).default;
    } else {
      const fallbackEntry = Object.entries(defaultFallback)[0];
      if (fallbackEntry) img = (await fallbackEntry[1]()).default;
    }
    return { ...room, photo: img };
  })
);
---

<section id="rooms" class="py-24 px-4 bg-surface-light dark:bg-surface-dark transition-colors duration-500 overflow-hidden">
  <div class="max-w-[1400px] mx-auto">
    
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll space-y-3">
      <span class="tag-dash-title block">
        {t('rooms.sectionLabel')}
      </span>
      <h2 class="font-display text-4xl sm:text-5xl lg:text-7xl text-text-primary-light dark:text-white leading-tight">
        {t('roomsSection.heading')}
      </h2>
      <p class="mt-4 text-base sm:text-lg text-text-secondary-light dark:text-text-secondary-dark font-body font-light">
        {t('roomsSection.subheading')}
      </p>
    </div>

    <!-- Accordion Layout -->
    <div class="flex flex-col lg:flex-row h-[800px] lg:h-[650px] w-full gap-2 lg:gap-4 animate-on-scroll">
      {roomsWithPhotos.map((room) => (
        <a
          href={getRelativeLocaleUrl(lang, `rooms/${room.slug}`)}
          data-astro-prefetch="tap"
          class="room-accordion-item relative group flex-1 hover:flex-[3] transition-[flex] duration-700 ease-in-out overflow-hidden rounded-2xl border border-black/5 dark:border-white/5 shadow-xl bg-surface-dark cursor-pointer block"
        >
          <!-- Background Image -->
          {room.photo ? (
            <Image
              src={room.photo}
              alt={room.name[lang] || room.name.en || "Room"}

              width={1000}
              height={800}
              format="webp"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-[10s] ease-linear group-hover:scale-110"
              loading="lazy"
            />
          ) : (
             <div class="absolute inset-0 bg-primary-dark w-full h-full"></div>
          )}

          <!-- Gradient Overlay: darker at bottom for text, subtle elsewhere -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent transition-opacity duration-500 group-hover:opacity-90"></div>
          
          <!-- Content Container -->
          <div class="absolute inset-0 p-6 sm:p-8 flex flex-col justify-end">
            <!-- Non-hovered state text (Vertical on Desktop, Horizontal on Mobile) -->
            <div class="lg:-rotate-90 lg:origin-bottom-left lg:absolute lg:bottom-12 lg:left-14 whitespace-nowrap lg:group-hover:opacity-0 transition-opacity duration-300">
               <h3 class="font-display text-2xl sm:text-3xl text-white tracking-wide shadow-black/50 drop-shadow-md">
                 {room.name[lang]}
               </h3>
            </div>

            <!-- Hovered state expanded content -->
            <div class="opacity-100 lg:opacity-0 lg:group-hover:opacity-100 transition-all duration-500 transform translate-y-4 lg:group-hover:translate-y-0 delay-100 max-w-lg">
               <!-- Price Tag -->
               <div class="inline-block px-4 py-1.5 mb-4 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-secondary font-mono font-bold text-sm">
                 ${room.pricePerNight} USD <span class="text-xs font-normal text-white/70">{t('rooms.perNight')}</span>
               </div>
               
               <h3 class="font-display text-3xl sm:text-5xl text-white mb-2 leading-tight">
                 {room.name[lang]}
               </h3>
               
               <div class="flex items-center gap-4 mb-6 text-white/80 font-mono text-xs uppercase tracking-wider">
                 <span class="flex items-center gap-1.5">
                   <svg class="w-4 h-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                     <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                   </svg>
                   {t('rooms.upTo')} {room.maxGuests}
                 </span>
                 <span class="w-1.5 h-1.5 rounded-full bg-secondary/50"></span>
                 <span>{translateBeds(room.beds, lang)}</span>
               </div>
               
               <!-- CTA -->
               <span class="inline-flex items-center gap-3 text-secondary font-bold text-sm uppercase tracking-widest hover:text-white transition-colors">
                 {t('roomsSection.viewDetails')}
                 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                   <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                 </svg>
               </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Mobile fallback text -->
    <div class="text-center mt-8 lg:hidden animate-on-scroll">
      <p class="text-xs text-text-secondary-light/60 dark:text-text-secondary-dark/60 uppercase tracking-widest">
         {t('roomsSection.tapHint')}
      </p>
    </div>

  </div>
</section>
