---
import { Image } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { rooms } from '../data/rooms';
import { useTranslations } from '../i18n/utils';
import { translateBeds } from '../utils/helpers';

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';
const t = useTranslations(lang);

// Dynamically import first photo of each room
const allImages = import.meta.glob<{ default: ImageMetadata }>('../assets/rooms/**/*.jpg');
const defaultFallback = import.meta.glob<{ default: ImageMetadata }>('../assets/hotel/fallback-room-pasillo.jpg');

const roomsWithPhotos = await Promise.all(
  rooms.map(async (room) => {
    const roomImages = Object.entries(allImages)
      .filter(([path]) => path.includes(`/${room.photoFolder}/`))
      .sort(([a], [b]) => a.localeCompare(b));
    
    let img = null;
    if (roomImages.length > 0) {
      img = (await roomImages[0][1]()).default;
    } else {
      const fallbackEntry = Object.entries(defaultFallback)[0];
      if (fallbackEntry) img = (await fallbackEntry[1]()).default;
    }
    return { ...room, photo: img };
  })
);
---

<section id="rooms" class="py-24 px-4 bg-surface-light dark:bg-surface-dark transition-colors duration-300 relative">
  <div class="max-w-7xl mx-auto">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-14 animate-on-scroll">
      <span class="text-xs font-semibold text-primary dark:text-purple-pastel uppercase tracking-widest block mb-2">
        {t('rooms.sectionLabel')}
      </span>
      <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl text-text-primary-light dark:text-white leading-tight">
        {lang === 'es' ? 'HABITACIONES DE AUTOR' : 'BOUTIQUE ROOM COLLECTION'}
      </h2>
      <p class="mt-4 text-base sm:text-lg text-text-secondary-light dark:text-text-secondary-dark font-body font-light">
        {lang === 'es'
          ? 'Espacios acogedores diseñados para el descanso perfecto tras explorar las maravillas del Valle Sagrado y Machu Picchu.'
          : 'Serene sanctuaries designed for deep rest after exploring Machu Picchu and the Sacred Valley.'}
      </p>
    </div>

    <!-- Filter Pills Ribbon -->
    <div class="flex flex-wrap items-center justify-center gap-2 sm:gap-3 mb-14 animate-on-scroll">
      <button
        class="room-filter-pill px-6 py-2.5 rounded-full text-xs font-semibold uppercase tracking-wider transition-all duration-300 cursor-pointer bg-primary text-white shadow-md"
        data-filter="all"
      >
        {lang === 'es' ? 'Todas las Habitaciones' : 'All Rooms'}
      </button>
      {roomsWithPhotos.map((room) => (
        <button
          class="room-filter-pill px-6 py-2.5 rounded-full text-xs font-semibold uppercase tracking-wider transition-all duration-300 cursor-pointer bg-surface-card-light dark:bg-surface-card-dark text-text-secondary-light dark:text-text-secondary-dark border border-black/5 dark:border-white/5 hover:border-secondary hover:text-secondary"
          data-filter={room.slug}
        >
          {room.name[lang]}
        </button>
      ))}
    </div>

    <!-- Luxury Rooms Grid Showcase -->
    <div id="rooms-cards-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8 lg:gap-10">
      {roomsWithPhotos.map((room) => (
        <div
          class="room-display-card glow-card-hover group relative rounded-3xl overflow-hidden bg-surface-card-light dark:bg-surface-card-dark border border-black/10 dark:border-white/10 shadow-xl flex flex-col justify-between transition-all duration-500"
          data-room-slug={room.slug}
        >
          <!-- Image Header with Gradient & Glowing Price Tag -->
          <div class="relative aspect-[16/10] overflow-hidden">
            {room.photo ? (
              <Image
                src={room.photo}
                alt={room.name[lang]}
                width={800}
                height={500}
                format="webp"
                class="w-full h-full object-cover transform group-hover:scale-108 transition-transform duration-700"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full bg-surface-dark flex items-center justify-center">
                <span class="text-white font-display text-2xl font-bold">{room.name[lang]}</span>
              </div>
            )}
            
            <!-- Vignette -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>

            <!-- Glowing Price Badge -->
            <div class="absolute top-4 right-4 px-4 py-2 rounded-2xl bg-black/60 backdrop-blur-md border border-secondary/40 text-secondary font-display font-bold text-lg shadow-lg">
              ${room.pricePerNight} USD <span class="text-xs font-normal text-white/80">/ {lang === 'es' ? 'noche' : 'night'}</span>
            </div>

            <!-- Room Name Overlay -->
            <div class="absolute bottom-4 left-6 right-6">
              <span class="text-xs uppercase tracking-widest text-secondary font-semibold block mb-1">
                USGAR Hotels San Pedro
              </span>
              <h3 class="font-display text-2xl sm:text-3xl text-white font-bold drop-shadow-md">
                {room.name[lang]}
              </h3>
            </div>
          </div>

          <!-- Card Body & Capacity Chips -->
          <div class="p-6 sm:p-8 space-y-6 flex-1 flex flex-col justify-between">
            <p class="text-sm sm:text-base text-text-secondary-light dark:text-text-secondary-dark font-body font-light leading-relaxed line-clamp-3">
              {room.description[lang]}
            </p>

            <!-- Features Grid -->
            <div class="grid grid-cols-2 gap-3 pt-4 border-t border-black/5 dark:border-white/5 text-xs text-text-secondary-light dark:text-text-secondary-dark font-medium">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-tertiary dark:text-mint" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>{t('rooms.upTo')} {room.maxGuests} {lang === 'es' ? 'huéspedes' : 'guests'}</span>
              </div>

              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-tertiary dark:text-mint" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{translateBeds(room.beds, lang)}</span>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="pt-4 flex items-center justify-between gap-4">
              <a
                href={getRelativeLocaleUrl(lang, `rooms/${room.slug}`)}
                data-astro-prefetch="tap"
                class="inline-flex items-center gap-2 text-primary dark:text-secondary font-semibold text-sm hover:underline"
              >
                <span>{lang === 'es' ? 'Ver Galería y Detalles' : 'View Gallery & Details'}</span>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>

              <a
                href={getRelativeLocaleUrl(lang, `book?roomType=${room.slug}`)}
                data-astro-prefetch="tap"
                class="bg-tertiary hover:bg-tertiary-dark text-white text-xs font-semibold px-5 py-2.5 rounded-xl transition-all duration-300 shadow-md hover:shadow-lg uppercase tracking-wider"
              >
                {t('rooms.bookNow')}
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  function initRoomFilters() {
    const pills = document.querySelectorAll('.room-filter-pill');
    const cards = document.querySelectorAll('.room-display-card');

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        const filter = pill.getAttribute('data-filter');

        pills.forEach(p => {
          p.classList.remove('bg-primary', 'text-white', 'shadow-md');
          p.classList.add('bg-surface-card-light', 'dark:bg-surface-card-dark', 'text-text-secondary-light', 'dark:text-text-secondary-dark');
        });

        pill.classList.add('bg-primary', 'text-white', 'shadow-md');
        pill.classList.remove('bg-surface-card-light', 'dark:bg-surface-card-dark', 'text-text-secondary-light', 'dark:text-text-secondary-dark');

        cards.forEach(card => {
          const slug = card.getAttribute('data-room-slug');
          if (filter === 'all' || slug === filter) {
            card.classList.remove('hidden');
            requestAnimationFrame(() => card.classList.add('opacity-100', 'scale-100'));
          } else {
            card.classList.add('hidden');
            card.classList.remove('opacity-100', 'scale-100');
          }
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initRoomFilters);
</script>
