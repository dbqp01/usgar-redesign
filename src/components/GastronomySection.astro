---
import { Image } from 'astro:assets';
import desayunoImg from '../assets/hotel/fallback-room-desayuno.jpg';
import recepcionImg from '../assets/hotel/hero-slide-recepcion.jpg';
import patioImg from '../assets/hotel/hero-slide-patio.jpg';

import type { Locale } from '../i18n/utils';

const lang = (Astro.currentLocale || 'en') as Locale;

const culinaryOffers = [
  {
    id: 'buffet',
    title: { en: 'Daily Buffet Breakfast', es: 'Desayuno Buffet Diario', fr: 'Petit-Déjeuner Buffet Quotidien', pt: 'Café da Manhã Buffet Diário' },
    schedule: '06:00 AM - 09:00 AM',
    metric: '100%',
    metricLabel: { en: 'Included in Stay', es: 'Incluido en tu Estadía', fr: 'Inclus dans le Séjour', pt: 'Incluído na Estadia' },
    desc: {
      en: 'Fresh tropical fruits, artisan breads, eggs prepared to order, regional cheeses, coffee, and authentic hot Andean herbal teas.',
      es: 'Frutas frescas del valle, panes artesanales, huevos al gusto, quesos regionales, café pasado e infusiones andinas calientes.',
      fr: 'Fruits frais, pains artisanaux, œufs préparés à la commande, fromages régionaux, café et infusions andines chaudes.',
      pt: 'Frutas frescas, pães artesanais, ovos preparados na hora, queijos regionais, café e infusões andinas quentes.'
    },
    image: desayunoImg,
    size: 'col-span-1 lg:col-span-2 row-span-2'
  },
  {
    id: 'teas',
    title: { en: 'Coca & Muña Station', es: 'Estación de Mates', fr: 'Station de Boissons Chaudes', pt: 'Estação de Chás' },
    schedule: '24 Hours',
    metric: '24/7',
    metricLabel: { en: 'Complimentary', es: 'De Cortesía', fr: 'Gracieux', pt: 'De Cortesia' },
    desc: {
      en: 'Unlimited hot Coca and Muña leaf infusions to prevent altitude sickness and stay energized.',
      es: 'Infusiones ilimitadas de hoja de Coca y Muña para prevenir el soroche y mantenerte activo.',
      fr: 'Infusions illimitées de feuilles de Coca et Muña pour prévenir le mal de l\'altitude.',
      pt: 'Infusões ilimitadas de folhas de Coca e Muña para prevenir o soroche.'
    },
    image: recepcionImg,
    size: 'col-span-1 lg:col-span-1 row-span-1'
  },
  {
    id: 'cafeteria',
    title: { en: 'Evening Cafeteria', es: 'Cafetería Nocturna', fr: 'Cafétéria du Soir', pt: 'Cafetaria Noturna' },
    schedule: 'Until 22:00 PM',
    metric: '22:00',
    metricLabel: { en: 'Open Daily', es: 'Abierto Diario', fr: 'Ouvert Tous les Jours', pt: 'Aberto Diariamente' },
    desc: {
      en: 'Warm beverages, light snacks, and cozy seating after your Machu Picchu tours.',
      es: 'Bebidas calientes, bocadillos ligeros y ambiente acogedor después de tus tours a Machu Picchu.',
      fr: 'Boissons chaudes, en-cas légers et ambiance chaleureuse après vos visites.',
      pt: 'Bebidas quentes, lanches leves e ambiente acolhedor após seus passeios.'
    },
    image: patioImg,
    size: 'col-span-1 lg:col-span-1 row-span-1'
  }
];
---

<section id="gastronomy" class="py-24 px-4 bg-surface-light dark:bg-surface-dark relative overflow-hidden transition-colors duration-500">
  <div class="max-w-[1400px] mx-auto">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll space-y-3">
      <span class="tag-dash-title block">
        {lang === 'es' ? 'GASTRONOMÍA & CAFETERÍA' : lang === 'fr' ? 'GASTRONOMIE & CAFÉTÉRIA' : lang === 'pt' ? 'GASTRONOMIA & CAFETARIA' : 'CULINARY & COFFEE'}
      </span>
      <h2 class="font-display text-4xl sm:text-5xl lg:text-7xl text-text-primary-light dark:text-white leading-tight">
        AUKA RESTOBAR
      </h2>
      <p class="mt-4 text-base sm:text-lg text-text-secondary-light dark:text-text-secondary-dark font-body font-light">
        {lang === 'es'
          ? 'Una experiencia gastronómica inolvidable con ingredientes andinos frescos en el corazón del Cusco.'
          : lang === 'fr'
          ? 'Une expérience gastronomique inoubliable avec des ingrédients andins frais au cœur de Cusco.'
          : lang === 'pt'
          ? 'Uma experiência gastronômica inesquecível com ingredientes andinos frescos no coração de Cusco.'
          : 'An unforgettable culinary journey with fresh Andean ingredients in the historic heart of Cusco.'}
      </p>
    </div>

    <!-- Bento Box Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 auto-rows-[300px] gap-4 sm:gap-6 animate-on-scroll">
      {culinaryOffers.map((offer) => (
        <div class={`group relative rounded-3xl overflow-hidden shadow-xl border border-black/5 dark:border-white/5 img-hover-zoom cursor-pointer ${offer.size}`}>
          <!-- Background Image -->
          <Image
            src={offer.image}
            alt={offer.title[lang] || offer.title.en || offer.title.es || 'Gastronomy'}

            width={1200}
            height={800}
            format="webp"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1.5s] group-hover:scale-105"
            loading="lazy"
          />
          
          <!-- Gradient Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent transition-opacity duration-500"></div>
          
          <!-- Badges -->
          <div class="absolute top-6 left-6 px-4 py-1.5 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white font-mono text-xs uppercase tracking-wider">
            {offer.metricLabel[lang]}
          </div>

          <!-- Content -->
          <div class="absolute inset-0 p-6 sm:p-8 flex flex-col justify-end transform transition-transform duration-500 group-hover:-translate-y-2">
            <h3 class="font-display font-bold text-3xl sm:text-4xl text-white mb-2 drop-shadow-md group-hover:text-secondary transition-colors">
              {offer.title[lang]}
            </h3>
            
            <div class="flex items-center gap-2 mb-3 text-secondary font-mono text-xs uppercase tracking-wider">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {offer.schedule}
            </div>

            <p class="text-sm text-white/80 font-light opacity-0 group-hover:opacity-100 transition-opacity duration-500 transform translate-y-4 group-hover:translate-y-0 delay-100">
              {offer.desc[lang]}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
