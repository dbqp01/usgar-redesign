---
import { Image } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';
import desayunoImg from '../assets/hotel/fallback-room-desayuno.jpg';
import recepcionImg from '../assets/hotel/hero-slide-recepcion.jpg';
import patioImg from '../assets/hotel/hero-slide-patio.jpg';

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';

const culinaryOffers = [
  {
    id: 'buffet',
    title: { en: 'Daily Buffet Breakfast', es: 'Desayuno Buffet Diario' },
    schedule: '06:00 AM - 09:00 AM',
    highlight: { en: 'Included in your stay', es: 'Incluido en tu estadía' },
    desc: {
      en: 'Fresh tropical fruits, artisan breads, eggs prepared to order, regional cheeses, coffee, and authentic hot Andean herbal teas.',
      es: 'Frutas frescas del valle, panes artesanales, huevos preparados al gusto, quesos regionales, café pasado e infusiones andinas calientes.'
    },
    image: desayunoImg
  },
  {
    id: 'teas',
    title: { en: 'Coca & Muña Tea Station', es: 'Estación de Mates & Aclimatación' },
    schedule: '24 Hours / 7 Days',
    highlight: { en: 'Complimentary 24/7', es: 'De cortesía 24/7' },
    desc: {
      en: 'Enjoy unlimited hot Coca and Muña leaf infusions throughout the day to prevent altitude sickness and stay energized during your Cusco tours.',
      es: 'Disfruta de infusiones ilimitadas de hoja de coca y muña caliente durante todo el día para prevenir el soroche y mantener tu energía en las excursiones.'
    },
    image: patioImg
  },
  {
    id: 'restobar',
    title: { en: 'Auka Restobar & Snacks', es: 'Auka Restobar & Piqueos' },
    schedule: '12:00 PM - 10:00 PM',
    highlight: { en: 'Peruvian Specialties', es: 'Especialidades Peruanas' },
    desc: {
      en: 'Savor traditional Andean appetizers, native potato platters, hot soups, and refreshing Pisco drinks in a warm historic courtyard atmosphere.',
      es: 'Saboréate con piqueos andinos tradicionales, tablas de papas nativas, sopas reconfortantes y cócteles a base de Pisco en nuestro acogedor patio.'
    },
    image: recepcionImg
  }
];
---

<section id="gastronomy" class="py-24 px-4 bg-purple-bg/20 dark:bg-surface-dark relative overflow-hidden transition-colors duration-300">
  <div class="max-w-7xl mx-auto">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-secondary/15 border border-secondary/30 text-secondary-dark dark:text-secondary text-xs font-semibold uppercase tracking-widest mb-4">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-ping"></span>
        <span>{lang === 'es' ? 'Experiencia Gastronómica en San Pedro' : 'San Pedro Culinary Experience'}</span>
      </div>
      <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl text-primary dark:text-white tracking-tight">
        {lang === 'es' ? 'AUKA RESTOBAR & CAFETERÍA' : 'AUKA RESTOBAR & COFFEE SHOP'}
      </h2>
      <p class="mt-4 text-base sm:text-lg text-text-secondary-light dark:text-text-secondary-dark font-body font-light">
        {lang === 'es'
          ? 'Sabores auténticos del Cusco, ingredientes andinos y calidez impecable en cada momento del día.'
          : 'Authentic flavors of Cusco, native Andean ingredients, and warm hospitality throughout your day.'}
      </p>
    </div>

    <!-- Culinary Cards Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      {culinaryOffers.map((offer) => (
        <div class="glow-card-hover group bg-surface-card-light dark:bg-surface-card-dark rounded-3xl p-6 sm:p-8 border border-black/5 dark:border-white/10 shadow-xl flex flex-col justify-between transition-all duration-500">
          
          <div class="space-y-6">
            <!-- Image Thumbnail with Schedule Overlay -->
            <div class="relative aspect-[16/10] rounded-2xl overflow-hidden shadow-md">
              <Image
                src={offer.image}
                alt={offer.title[lang]}
                width={500}
                height={350}
                format="webp"
                class="w-full h-full object-cover transform group-hover:scale-108 transition-transform duration-700"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
              
              <div class="absolute top-3 left-3 px-3 py-1 rounded-full bg-black/60 backdrop-blur-md text-secondary text-[11px] font-semibold uppercase tracking-wider border border-secondary/30">
                {offer.highlight[lang]}
              </div>

              <div class="absolute bottom-3 left-3 text-white text-xs font-semibold flex items-center gap-1.5">
                <svg class="w-4 h-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>{offer.schedule}</span>
              </div>
            </div>

            <!-- Title & Description -->
            <div class="space-y-2">
              <h3 class="font-display text-2xl text-text-primary-light dark:text-white font-bold group-hover:text-primary dark:group-hover:text-secondary transition-colors">
                {offer.title[lang]}
              </h3>
              <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark font-body font-light leading-relaxed">
                {offer.desc[lang]}
              </p>
            </div>
          </div>

          <!-- Bottom Accent -->
          <div class="pt-6 border-t border-black/5 dark:border-white/5 flex items-center justify-between text-xs font-semibold text-primary dark:text-secondary">
            <span>{lang === 'es' ? 'Servicio Exclusivo' : 'Hotel Service'}</span>
            <span class="w-8 h-8 rounded-full bg-secondary/15 flex items-center justify-center group-hover:bg-secondary group-hover:text-primary-dark transition-all">
              →
            </span>
          </div>

        </div>
      ))}
    </div>

    <!-- CTA Ribbon -->
    <div class="bg-surface-card-dark text-white p-8 sm:p-10 rounded-3xl border border-secondary/30 shadow-2xl flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="space-y-2 text-center md:text-left">
        <span class="text-xs uppercase tracking-widest text-secondary font-semibold">
          {lang === 'es' ? 'Atención y Mates de Cortesía' : 'Complimentary Andean Teas'}
        </span>
        <h4 class="font-display text-2xl sm:text-3xl font-bold">
          {lang === 'es' ? '¿Tienes consultas sobre dietas o horarios?' : 'Have dietary preferences or schedule questions?'}
        </h4>
      </div>

      <a
        href={getRelativeLocaleUrl(lang, 'contact')}
        class="bg-secondary hover:bg-secondary-light text-primary-dark font-semibold px-8 py-4 rounded-xl transition-all duration-300 shadow-lg hover:shadow-secondary/30 whitespace-nowrap uppercase tracking-wider text-xs"
      >
        {lang === 'es' ? 'Contactar al Hotel' : 'Contact Us'}
      </a>
    </div>

  </div>
</section>
