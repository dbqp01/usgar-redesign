---
import { Image } from 'astro:assets';
import { useTranslations } from "../i18n/utils";
import aboutData from "../content/about/about.json";
import patioImg from '../assets/hotel/hero-slide-patio.jpg';
import fachadaImg from '../assets/hotel/fallback-room-fachada.jpg';

import type { Locale } from '../i18n/utils';

const lang = (Astro.currentLocale || 'en') as Locale;

const t = useTranslations(lang);

const title = lang === 'es' ? aboutData.title_es : aboutData.title_en;
const purpose = lang === 'es' ? aboutData.purpose_es : aboutData.purpose_en;
---

<section id="about" class="py-32 px-4 bg-surface-light dark:bg-surface-dark transition-colors duration-500 overflow-hidden relative">
  <div class="max-w-[1400px] mx-auto relative z-10">
    
    <!-- Editorial Layout: Staggered columns -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      
      <!-- Text Content (Left on Desktop) -->
      <div class="lg:col-span-5 space-y-10 animate-on-scroll lg:pr-12">
        <div class="space-y-6">
          <span class="tag-dash-title block">
            {t('about.sectionLabel')}
          </span>
          <h2 class="font-display text-5xl sm:text-6xl lg:text-7xl text-text-primary-light dark:text-white leading-[1.1]">
            {title}
          </h2>
        </div>
        
        <p class="text-lg sm:text-xl text-text-secondary-light dark:text-text-secondary-dark font-body font-light leading-relaxed">
          {purpose}
        </p>
        
        <!-- Minimalist Values List -->
        <div class="pt-8 border-t border-black/10 dark:border-white/10">
          <div class="grid grid-cols-2 gap-y-6 gap-x-4">
             {aboutData.values.slice(0, 4).map((valor) => {
               const valTitle = lang === 'es' ? valor.title_es : valor.title_en;
               return (
                 <div class="flex items-center gap-3">
                   <div class="w-8 h-px bg-secondary"></div>
                   <h3 class="font-display tracking-widest uppercase text-xs font-bold text-primary dark:text-white">
                     {valTitle}
                   </h3>
                 </div>
               );
             })}
          </div>
        </div>
        
      </div>

      <!-- Image Composition (Right on Desktop) -->
      <div class="lg:col-span-7 relative h-[600px] sm:h-[800px] lg:h-[700px] w-full animate-on-scroll">
        
        <!-- Main Large Image -->
        <div class="absolute top-0 right-0 w-4/5 h-[80%] rounded-3xl overflow-hidden shadow-2xl img-hover-zoom z-10 border border-black/5 dark:border-white/5">
          <Image
            src={patioImg}
            alt="Patio Inca Colonial USGAR Hotels"
            width={800}
            height={1000}
            format="webp"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <!-- Offset Smaller Image -->
        <div class="absolute bottom-0 left-0 w-[55%] h-[55%] rounded-3xl overflow-hidden shadow-2xl img-hover-zoom z-20 border-4 border-surface-light dark:border-surface-dark">
          <Image
            src={fachadaImg}
            alt="Fachada USGAR Hotels"
            width={600}
            height={600}
            format="webp"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        
        <!-- Decorative Elements -->
        <div class="absolute top-1/2 left-1/4 -translate-y-1/2 -translate-x-1/2 w-48 h-48 rounded-full border border-secondary/30 z-0 hidden sm:block animate-pulse-soft"></div>
      </div>
      
    </div>
    
  </div>
</section>
