---
import { useTranslations } from '../i18n/utils';
import { siteSettings } from '../data/settings';

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';
const t = useTranslations(lang);
---

<section id="map-section" class="py-24 px-4 bg-surface-card-light dark:bg-surface-dark text-text-primary-light dark:text-white relative overflow-hidden transition-colors duration-500">
  <div class="max-w-[1400px] mx-auto relative z-10">
    <div class="text-center mb-16 animate-on-scroll space-y-3">
      <span class="tag-dash-title block">
        {t('map.sectionLabel')}
      </span>
      <h2 class="font-display text-4xl sm:text-5xl lg:text-7xl text-text-primary-light dark:text-white tracking-tight leading-tight">
        {t('map.title')}
      </h2>
      <p class="mt-4 text-base sm:text-lg text-text-secondary-light dark:text-text-secondary-dark font-body font-light max-w-2xl mx-auto">
        {t('map.description')}
      </p>
    </div>

    <!-- Map Container -->
    <div
      id="hotel-map"
      class="w-full h-96 sm:h-[500px] lg:h-[600px] rounded-3xl overflow-hidden shadow-2xl animate-on-scroll relative z-10"
      data-lat={String(siteSettings.latitude)}
      data-lng={String(siteSettings.longitude)}
      data-hotel-name={siteSettings.hotelName}
      data-address-es={siteSettings.address.es}
      data-address-en={siteSettings.address.en}
    >
      <div class="w-full h-full flex items-center justify-center text-purple-pastel">
        <div class="text-center">
          <svg class="w-12 h-12 mx-auto mb-3 opacity-50 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <p class="text-sm">{lang === 'es' ? 'Cargando mapa interactivo...' : 'Interactive map loading...'}</p>
          <p class="text-xs mt-1 opacity-60 font-mono">{siteSettings.address[lang]}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Track initialized map containers to prevent double-init
  const initializedMaps = new WeakSet<HTMLElement>();

  async function initMap() {
    const container = document.getElementById('hotel-map');
    if (!container || initializedMaps.has(container)) return;
    initializedMaps.add(container);

    // Read config from data attributes (server → client bridge)
    const lat = parseFloat(container.dataset.lat || '-13.5226');
    const lng = parseFloat(container.dataset.lng || '-71.9828');
    const hotelName = container.dataset.hotelName || 'USGAR Hotels';
    const addressEs = container.dataset.addressEs || 'San Pedro, Cusco, Perú';
    const addressEn = container.dataset.addressEn || 'San Pedro, Cusco, Peru';

    // Dynamic import — Leaflet is only loaded when the map becomes visible
    const L = (await import('leaflet')).default;
    await import('leaflet/dist/leaflet.css');
    const logoIsotipo = (await import('../assets/logos/Logo usgar isotipo.png')).default;

    container.innerHTML = '';

    const map = L.map('hotel-map', {
      scrollWheelZoom: false
    }).setView([lat, lng], 17);

    const getTileUrl = () => {
      const isDark = document.documentElement.classList.contains('dark');
      return isDark
        ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png'
        : 'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png';
    };

    const tileLayer = L.tileLayer(getTileUrl(), {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
      maxZoom: 19
    }).addTo(map);

    const iconUrl = typeof logoIsotipo === 'string' ? logoIsotipo : logoIsotipo.src;
    const customIcon = L.icon({
      iconUrl: iconUrl,
      iconSize: [42, 42],
      iconAnchor: [21, 42],
      popupAnchor: [0, -42]
    });

    const marker = L.marker([lat, lng], { icon: customIcon }).addTo(map);

    const isEs = document.documentElement.lang === 'es';
    const addr = isEs ? addressEs : addressEn;
    const dirLabel = isEs ? 'Cómo llegar' : 'Directions';
    const popupContent = `<b>${hotelName}</b><br>${addr}<br><a href="https://maps.openrouteservice.org" target="_blank" class="text-primary hover:underline text-xs">${dirLabel}</a>`;

    marker.bindPopup(popupContent).openPopup();

    const themeObserver = new MutationObserver(() => {
      tileLayer.setUrl(getTileUrl());
    });
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

    document.addEventListener('astro:before-swap', () => {
      themeObserver.disconnect();
      map.remove();
    }, { once: true });
  }

  function setupMapObserver() {
    const container = document.getElementById('hotel-map');
    if (!container || initializedMaps.has(container)) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          initMap();
          observer.disconnect();
        }
      });
    }, { rootMargin: '200px' });

    observer.observe(container);
  }

  document.addEventListener('astro:page-load', setupMapObserver);
</script>
