---
import { reviews } from '../data/reviews';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="pb-16 -mt-4 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 mb-4 text-center">
    <span class="text-xs font-semibold text-primary uppercase tracking-widest">
      {t("reviews.sectionLabel")}
    </span>
  </div>
  <div class="marquee-container">
    <div class="marquee-content">
      {
        reviews.map((review) => (
          <div class="flex-shrink-0 w-80 bg-surface-card-light dark:bg-surface-card-dark p-5 rounded-2xl border border-black/5 dark:border-white/5 shadow-sm space-y-3">
            <div class="flex items-center justify-between">
              <div class="flex gap-0.5 text-secondary">
                {Array.from({ length: 5 }).map(() => (
                  <svg
                    class="w-3.5 h-3.5 fill-current text-secondary"
                    viewBox="0 0 20 20"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <span class="text-xs text-text-secondary-light dark:text-text-secondary-dark">
                {review.country} {review.name}
              </span>
            </div>
            <p class="text-xs text-text-secondary-light dark:text-text-secondary-dark italic leading-relaxed">
              "{review.text[lang]}"
            </p>
          </div>
        ))
      }
    </div>
    <!-- Duplicate for seamless scroll -->
    <div class="marquee-content" aria-hidden="true">
      {
        reviews.map((review) => (
          <div class="flex-shrink-0 w-80 bg-surface-card-light dark:bg-surface-card-dark p-5 rounded-2xl border border-black/5 dark:border-white/5 shadow-sm space-y-3">
            <div class="flex items-center justify-between">
              <div class="flex gap-0.5 text-secondary">
                {Array.from({ length: 5 }).map(() => (
                  <svg
                    class="w-3.5 h-3.5 fill-current text-secondary"
                    viewBox="0 0 20 20"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <span class="text-xs text-text-secondary-light dark:text-text-secondary-dark">
                {review.country} {review.name}
              </span>
            </div>
            <p class="text-xs text-text-secondary-light dark:text-text-secondary-dark italic leading-relaxed">
              "{review.text[lang]}"
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
