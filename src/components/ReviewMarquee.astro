---
import { reviews } from '../data/reviews';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-24 bg-surface-light dark:bg-surface-dark transition-colors duration-500">
  <div class="max-w-7xl mx-auto px-4 mb-16 text-center">
    <span class="tag-dash-title block">
      {t("reviews.sectionLabel")}
    </span>
    <h2 class="font-display text-4xl sm:text-5xl mt-4 text-text-primary-light dark:text-white">
      {lang === 'es' ? 'LO QUE DICEN DE NOSOTROS' : 'GUEST VOICES'}
    </h2>
  </div>
  
  <div class="marquee-wrapper">
    <div class="marquee-content gap-6 px-3">
      {
        reviews.map((review) => (
          <div class="flex-shrink-0 w-80 sm:w-96 bg-white/60 dark:bg-white/5 backdrop-blur-md p-8 rounded-3xl border border-black/5 dark:border-white/10 shadow-lg space-y-6 transform hover:-translate-y-2 transition-all duration-300 mx-3">
            <div class="flex justify-center gap-1 text-secondary">
              {Array.from({ length: 5 }).map(() => (
                <svg
                  class="w-4 h-4 fill-current text-secondary drop-shadow-sm"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            
            <p class="text-sm sm:text-base text-center text-text-secondary-light dark:text-text-secondary-dark font-body font-light italic leading-relaxed">
              "{review.text[lang]}"
            </p>
            
            <div class="text-center pt-4 border-t border-black/5 dark:border-white/5">
              <span class="block text-xs uppercase tracking-widest font-bold text-text-primary-light dark:text-white">
                {review.name}
              </span>
              <span class="block text-[10px] uppercase tracking-wider text-text-secondary-light/70 dark:text-text-secondary-dark/70 mt-1">
                {review.country}
              </span>
            </div>
          </div>
        ))
      }
    </div>
    
    <!-- Duplicate for seamless scroll -->
    <div class="marquee-content gap-6 px-3" aria-hidden="true">
      {
        reviews.map((review) => (
          <div class="flex-shrink-0 w-80 sm:w-96 bg-white/60 dark:bg-white/5 backdrop-blur-md p-8 rounded-3xl border border-black/5 dark:border-white/10 shadow-lg space-y-6 transform hover:-translate-y-2 transition-all duration-300 mx-3">
            <div class="flex justify-center gap-1 text-secondary">
              {Array.from({ length: 5 }).map(() => (
                <svg
                  class="w-4 h-4 fill-current text-secondary drop-shadow-sm"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            
            <p class="text-sm sm:text-base text-center text-text-secondary-light dark:text-text-secondary-dark font-body font-light italic leading-relaxed">
              "{review.text[lang]}"
            </p>
            
            <div class="text-center pt-4 border-t border-black/5 dark:border-white/5">
              <span class="block text-xs uppercase tracking-widest font-bold text-text-primary-light dark:text-white">
                {review.name}
              </span>
              <span class="block text-[10px] uppercase tracking-wider text-text-secondary-light/70 dark:text-text-secondary-dark/70 mt-1">
                {review.country}
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .marquee-wrapper {
    display: flex;
    overflow: hidden;
    /* padding top/bottom so shadows don't clip */
    padding: 2rem 0; 
    width: 100%;
    position: relative;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .marquee-content {
    display: flex;
    flex: 0 0 auto;
    min-width: 100%;
    z-index: 1;
    animation: scroll 40s linear infinite;
  }
  
  .marquee-wrapper:hover .marquee-content {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }
</style>
