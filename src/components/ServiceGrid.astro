---
import { services } from '../data/services';
import { useTranslations } from '../i18n/utils';
import SVGIcons from './icons/SVGIcons.astro';

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';
const t = useTranslations(lang);

// Grouping services for a more premium visual layout
const categories = [
  {
    title: {
      en: 'Essential Comforts',
      es: 'Comodidad Esencial'
    },
    desc: {
      en: 'Primary amenities ensuring a warm, seamless stay.',
      es: 'Comodidades principales que aseguran una estadía cálida y sin problemas.'
    },
    serviceIds: ['wifi', 'heating', 'hot-water', 'parking', 'recepcion-24h', 'bilingue', 'no-fumadores', 'limpieza']
  },
  {
    title: {
      en: 'Wellness & Dining',
      es: 'Bienestar y Sabores'
    },
    desc: {
      en: 'Indulge in authentic local tastes and relaxing therapies.',
      es: 'Disfruta de sabores locales auténticos y terapias relajantes.'
    },
    serviceIds: ['breakfast', 'restaurant', 'spa', 'tv', 'oxigeno', 'bebidas-calientes']
  },
  {
    title: {
      en: 'Travel & Experience',
      es: 'Viajes y Asistencia'
    },
    desc: {
      en: 'Everything you need to discover Cusco and Machu Picchu safely.',
      es: 'Todo lo necesario para descubrir Cusco y Machu Picchu con seguridad.'
    },
    serviceIds: ['transfer', 'tours', 'laundry', 'custodia-maletas', 'info-turistica', 'souvenirs', 'cambio-moneda']
  }
];
---

<section id="services" class="py-24 px-4 bg-purple-bg/30 dark:bg-surface-dark">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-sm font-semibold text-primary dark:text-purple-pastel uppercase tracking-widest">{t('services.sectionLabel')}</span>
      <h2 class="font-display text-4xl md:text-5xl mt-3 mb-4">
        {t('services.title')}
      </h2>
      <p class="text-lg text-text-secondary-light dark:text-text-secondary-dark max-w-2xl mx-auto font-body font-light">
        {t('services.description')}
      </p>
    </div>

    <!-- Grouped Services Grid (Restored) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
      {categories.map((cat, i) => (
        <div 
          class="animate-on-scroll glass p-8 rounded-3xl shadow-sm hover:shadow-lg transition-all duration-500 flex flex-col h-full group/category relative overflow-hidden"
          style={`transition-delay: ${i * 0.15}s`}
        >
          <!-- Hover gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-tertiary-light/5 opacity-0 group-hover/category:opacity-100 transition-opacity duration-500 rounded-3xl pointer-events-none"></div>
          <!-- Category Header -->
          <div class="mb-6 pb-4 border-b border-black/5 dark:border-white/5 text-center">
            <!-- FIXED CONTRAST HERE: dark:text-primary-light -->
            <h3 class="text-sm font-bold uppercase tracking-wider text-tertiary-light dark:text-tertiary-light">
              {cat.title[lang]}
            </h3>
            <p class="text-xs text-text-secondary-light dark:text-text-secondary-dark font-body leading-relaxed mt-2 max-w-[280px] mx-auto">
              {cat.desc[lang]}
            </p>
          </div>

          <!-- Service List inside Category -->
          <div class="space-y-4 flex-1">
            {cat.serviceIds.map((sId) => {
              const service = services.find(s => s.id === sId);
              if (!service) return null;
              
              return (
                <div 
                   class="flex items-start gap-4 p-4 rounded-2xl bg-white/50 dark:bg-white/5 border border-purple-pastel/10 dark:border-white/5 hover:border-tertiary-light/30 hover:bg-white/80 dark:hover:bg-white/10 transition-all duration-300 group/item hover:scale-[1.01] relative z-10"
                >
                  <!-- Premium Icon Box -->
                  <div class="w-10 h-10 rounded-xl bg-surface-card-light dark:bg-surface-card-dark border border-black/5 dark:border-white/5 flex items-center justify-center text-lg shadow-sm group-hover/item:border-tertiary/30 group-hover/item:text-tertiary transition-all duration-300 flex-shrink-0">
                    <!-- FIXED CONTRAST HERE: dark:text-primary-light -->
                    <SVGIcons name={service.id as any} class="w-5 h-5 text-tertiary-light dark:text-mint group-hover/item:text-tertiary group-hover/item:scale-110 transition-transform duration-300" />
                  </div>
                  
                  <!-- Text -->
                  <div>
                    <h4 class="font-semibold text-sm text-text-primary-light dark:text-text-primary-dark group-hover/item:text-tertiary transition-colors">
                      {service.name[lang]}
                    </h4>
                    <p class="text-xs text-text-secondary-light dark:text-text-secondary-dark leading-relaxed mt-1 font-body font-light">
                      {service.description[lang]}
                    </p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
