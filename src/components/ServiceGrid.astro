---
import { Image } from 'astro:assets';
import { services } from '../data/services';
import { useTranslations } from '../i18n/utils';

import type { Locale } from '../i18n/utils';

// Brand-approved photography for Bento Box
import patioImg from '../assets/hotel/hero-slide-patio.jpg';
import oxigenoImg from '../assets/hotel/fallback-room-oxigeno.jpg';
import cuscoImg from '../assets/hotel/hero-slide-cusco.jpg';
import matrimonialImg from '../assets/hotel/hero-slide-matrimonial.jpg';

const lang = (Astro.currentLocale || 'en') as Locale;
const t = useTranslations(lang);

// Grouping services for the Bento Box
const highlights: Array<{
  id: string;
  title: Record<string, string>;
  desc: Record<string, string>;
  img: ImageMetadata;
  size: string;
  icon: string;
}> = [
  {
    id: 'breakfast',
    title: { en: 'Andean Breakfast', es: 'Desayuno Andino', fr: 'Petit-Déjeuner Andin', pt: 'Café da Manhã Andino' },
    desc: { en: 'Local flavors to start your day right.', es: 'Sabores locales para empezar bien tu día.', fr: 'Saveurs locales pour bien démarrer votre journée.', pt: 'Sabores locais para começar bem o seu dia.' },
    img: patioImg,
    size: 'col-span-1 md:col-span-2 row-span-2',
    icon: '<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 19h16M7 19V7a2 2 0 012-2h6a2 2 0 012 2v12M17 9h2a2 2 0 012 2v2a2 2 0 01-2 2h-2" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 2v3M14 2v3" /></svg>'
  },
  {
    id: 'oxygen',
    title: { en: 'Oxygen & Acclimatization', es: 'Oxígeno & Aclimatación', fr: 'Oxygène & Acclimatation', pt: 'Oxigênio & Aclimação' },
    desc: { en: 'Complimentary oxygen to help you adjust to Cusco.', es: 'Oxígeno de cortesía para ayudarte a aclimatarte a Cusco.', fr: 'Oxygène gracieux pour vous aider à vous acclimater.', pt: 'Oxigênio de cortesia para ajudar na aclimação.' },
    img: oxigenoImg,
    size: 'col-span-1 md:col-span-1 row-span-1',
    icon: '<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>'
  },
  {
    id: 'tours',
    title: { en: 'Machu Picchu Tours', es: 'Tours Machu Picchu', fr: 'Tours Machu Picchu', pt: 'Passeios Machu Picchu' },
    desc: { en: 'Seamless travel assistance.', es: 'Asistencia de viaje sin complicaciones.', fr: 'Assistance voyage personnalisée.', pt: 'Assistência de viagem simplificada.' },
    img: cuscoImg,
    size: 'col-span-1 md:col-span-1 row-span-2',
    icon: '<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2L2 22h20L12 2zM12 8l3 6H9l3-6z" /></svg>'
  },
  {
    id: 'comfort',
    title: { en: 'Boutique Comfort', es: 'Confort Boutique', fr: 'Confort Boutique', pt: 'Conforto Boutique' },
    desc: { en: 'Crafted spaces for authentic rest.', es: 'Espacios diseñados para un descanso auténtico.', fr: 'Des espaces conçus pour un repos authentique.', pt: 'Espaços projetados para um descanso autêntico.' },
    img: matrimonialImg,
    size: 'col-span-1 md:col-span-1 row-span-1',
    icon: '<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>'
  }
];

---


<section id="services" class="py-28 px-4 bg-surface-light dark:bg-surface-dark transition-colors duration-500 relative overflow-hidden">
  
  <div class="max-w-[1400px] mx-auto relative z-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll space-y-3">
      <span class="tag-dash-title block">
        {t('services.sectionLabel')}
      </span>
      <h2 class="font-display text-4xl sm:text-5xl lg:text-7xl text-text-primary-light dark:text-white leading-tight">
        {lang === 'es' ? 'EXPERIENCIA COMPLETA' : lang === 'fr' ? 'EXPÉRIENCE COMPLÈTE' : lang === 'pt' ? 'EXPERIÊNCIA COMPLETA' : 'ELEVATED EXPERIENCE'}
      </h2>
      <p class="mt-4 text-base sm:text-lg text-text-secondary-light dark:text-text-secondary-dark font-body font-light">
        {lang === 'es' 
          ? 'Más que una habitación. Descubre todo lo que ofrecemos para hacer de tu visita a Cusco algo inolvidable.'
          : lang === 'fr'
          ? 'Plus qu\'une simple chambre. Découvrez tout ce que nous proposons pour rendre votre séjour à Cusco inoubliable.'
          : lang === 'pt'
          ? 'Mais do que um quarto. Descubra tudo o que oferecemos para tornar a sua visita a Cusco inesquecível.'
          : 'More than just a room. Discover everything we offer to make your visit to Cusco unforgettable.'}
      </p>
    </div>

    <!-- Bento Box Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 auto-rows-[250px] gap-4 sm:gap-6 animate-on-scroll">
      
      {highlights.map((item) => (
        <div class={`group relative rounded-3xl overflow-hidden shadow-xl border border-black/5 dark:border-white/5 img-hover-zoom ${item.size}`}>
          <!-- Background Image with Astro Image Optimization -->
          <Image
            src={item.img}
            alt={item.title[lang] || item.title.en || item.title.es || 'Service'}

            width={800}
            height={600}
            format="webp"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1.5s] group-hover:scale-105"
            loading="lazy"
          />
          
          <!-- Gradient Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent transition-opacity duration-500"></div>
          
          <!-- Content -->
          <div class="absolute inset-0 p-6 sm:p-8 flex flex-col justify-end">
            <div class="transform transition-transform duration-500 group-hover:-translate-y-2">
              <div class="w-12 h-12 rounded-2xl bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-2xl mb-4 shadow-lg text-white" aria-hidden="true" set:html={item.icon}>
              </div>
              <h3 class="font-display font-bold text-2xl sm:text-3xl text-white mb-2 drop-shadow-md">
                {item.title[lang]}
              </h3>
              <p class="text-sm text-white/80 font-light opacity-0 group-hover:opacity-100 transition-opacity duration-500 transform translate-y-4 group-hover:translate-y-0 delay-100">
                {item.desc[lang]}
              </p>
            </div>
          </div>
        </div>
      ))}
      
      <!-- Minimalist List Card (All Services) -->
      <div class="col-span-1 md:col-span-3 lg:col-span-4 row-span-1 rounded-3xl bg-white dark:bg-surface-card-dark border border-black/5 dark:border-white/5 shadow-xl p-8 flex flex-col justify-center relative overflow-hidden group">
        <!-- Decoration -->
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-secondary/10 to-transparent rounded-bl-full transform translate-x-8 -translate-y-8 transition-transform duration-500 group-hover:translate-x-0 group-hover:-translate-y-0"></div>
        
        <h3 class="font-display text-2xl font-bold text-text-primary-light dark:text-white mb-6">
          {lang === 'es' ? 'También incluimos:' : lang === 'fr' ? 'Aussi inclus :' : lang === 'pt' ? 'Também incluído:' : 'Also included:'}
        </h3>
        <div class="grid grid-cols-2 lg:grid-cols-6 gap-y-4 gap-x-6 relative z-10">
          {services.filter(s => !['breakfast', 'oxygen', 'tours'].includes(s.id)).slice(0, 6).map(service => (
            <div class="flex items-center gap-3 text-sm text-text-secondary-light dark:text-text-secondary-dark hover:text-text-primary-light dark:hover:text-white transition-colors duration-300">
              <div class="w-1.5 h-1.5 rounded-full bg-secondary flex-shrink-0 relative">
                <div class="absolute inset-0 rounded-full bg-secondary animate-ping opacity-50"></div>
              </div>
              <span class="truncate font-medium">{service.name[lang]}</span>
            </div>
          ))}
        </div>
      </div>
      
    </div>

  </div>
</section>
