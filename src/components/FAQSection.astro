---
import { Image } from 'astro:assets';
import faqData from "../content/faq/faq.json";
import { useTranslations } from '../i18n/utils';
import recepcionImg from '../assets/hotel/hero-slide-recepcion.jpg';

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';
const t = useTranslations(lang);
---

<section id="faq-section" class="py-32 px-4 bg-surface-light dark:bg-surface-dark transition-colors duration-500 overflow-hidden">
  <div class="max-w-[1400px] mx-auto">
    
    <div class="grid grid-cols-1 xl:grid-cols-12 gap-16 items-start">
      
      <!-- Massive Photo Left -->
      <div class="xl:col-span-5 h-[600px] xl:h-[800px] sticky top-24 animate-on-scroll">
        <div class="w-full h-full rounded-3xl overflow-hidden shadow-2xl img-hover-zoom relative">
          <Image
            src={recepcionImg}
            alt="Recepción 24 horas USGAR Hotels"
            width={800}
            height={1200}
            format="webp"
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
          
          <div class="absolute bottom-10 left-10 right-10 text-white space-y-4">
            <h3 class="font-display font-bold text-3xl sm:text-4xl text-secondary">
              {lang === 'es' ? 'Atención 24/7' : '24/7 Assistance'}
            </h3>
            <p class="text-sm text-white/80 font-light leading-relaxed">
              {lang === 'es' 
                ? 'Nuestro equipo bilingüe en recepción está listo las 24 horas para ayudarte con reservas, itinerarios a Machu Picchu y aclimatación.'
                : 'Our 24/7 bilingual front desk team is ready to assist with bookings, Machu Picchu tours, and altitude acclimatization.'}
            </p>
            <a 
              href="https://wa.me/51984000000" 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-block mt-4 text-xs font-body font-semibold tracking-wide uppercase border-b-2 border-secondary pb-1 hover:text-secondary transition-colors"
            >
              {lang === 'es' ? 'Contactar por WhatsApp' : 'Contact via WhatsApp'}
            </a>
          </div>
        </div>
      </div>
      
      <!-- FAQ Accordions Right -->
      <div class="xl:col-span-7 xl:pl-10 pt-10 xl:pt-20 space-y-12 animate-on-scroll" style="transition-delay: 0.1s;" id="faq-accordion">
        
        <!-- Header -->
        <div class="space-y-4 mb-12">
          <span class="tag-dash-title block">
            {t('faq.sectionLabel')}
          </span>
          <h2 class="font-display text-5xl sm:text-6xl lg:text-7xl tracking-tight leading-tight text-text-primary-light dark:text-white">
            {t('faq.title')}
          </h2>
        </div>

        <!-- Accordion List (Tailwind v4 open: modifiers) -->
        <div class="space-y-2">
          {faqData.questions.map((faq, i) => {
            const question = lang === 'es' ? faq.question_es : faq.question_en;
            const answer = lang === 'es' ? faq.answer_es : faq.answer_en;
            return (
              <details
                class="group border-b border-black/10 dark:border-white/10 open:border-b-transparent transition-all duration-300"
                data-faq-id={`faq-${i}`}
              >
                <summary class="flex items-center justify-between py-6 cursor-pointer font-body text-lg sm:text-xl font-semibold list-none select-none [&::-webkit-details-marker]:hidden text-text-primary-light dark:text-white hover:text-primary-light dark:hover:text-secondary transition-colors">
                  <span>{question}</span>
                  
                  <span class="flex-shrink-0 ml-4 text-secondary/60 group-hover:text-secondary group-open:rotate-45 transition-transform duration-300">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                    </svg>
                  </span>
                </summary>
                
                <div class="pb-8 pt-2 text-base sm:text-lg leading-relaxed text-text-secondary-light dark:text-text-secondary-dark font-body font-light details-content:mt-2 transition-all duration-500">
                  {answer}
                </div>
              </details>
            );
          })}
        </div>

      </div>

    </div>
  </div>
</section>

<script>
  function initFAQAccordion() {
    const accordion = document.getElementById('faq-accordion');
    if (!accordion) return;

    const items = accordion.querySelectorAll('details');

    items.forEach((details) => {
      details.addEventListener('toggle', () => {
        if (details.open) {
          items.forEach((otherDetails) => {
            if (otherDetails !== details && otherDetails.open) {
              otherDetails.open = false;
            }
          });
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initFAQAccordion);
</script>
