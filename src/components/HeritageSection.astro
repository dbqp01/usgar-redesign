---
import { Image } from 'astro:assets';
import patioImg from '../assets/hotel/hero-slide-patio.jpg';
import pasilloImg from '../assets/hotel/fallback-room-pasillo.jpg';

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';

const stats = [
  { value: '1650', label: { en: 'Colonial Foundation', es: 'Fundación Colonial' } },
  { value: '3,400m', label: { en: 'Highland Serenity', es: 'Serenidad Andina' } },
  { value: '24/7', label: { en: 'Oxygen & Tea', es: 'Oxígeno y Té' } }
];
---

<section id="heritage" class="py-32 px-4 bg-surface-card-dark text-white relative overflow-hidden transition-colors duration-500">
  <div class="max-w-7xl mx-auto">
    
    <!-- Editorial Split Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      
      <!-- Left: Massive Image with Parallax feel -->
      <div class="relative w-full aspect-[3/4] sm:aspect-square lg:aspect-[3/4] rounded-2xl overflow-hidden shadow-2xl img-hover-zoom animate-on-scroll">
        <Image
          src={patioImg}
          alt="Patio Inca Colonial USGAR Hotels"
          width={800}
          height={1200}
          format="webp"
          class="w-full h-full object-cover"
          loading="lazy"
        />
        <!-- Inner Glow & Gradient -->
        <div class="absolute inset-0 border border-white/10 rounded-2xl z-10 pointer-events-none"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-80 z-0"></div>
        
        <div class="absolute bottom-8 left-8 right-8 z-20">
           <h3 class="font-display text-4xl sm:text-5xl text-white tracking-wide">
             {lang === 'es' ? 'Fusión Inca-Colonial' : 'Inca-Colonial Fusion'}
           </h3>
           <p class="text-sm font-light text-white/80 mt-2 font-body max-w-sm">
             {lang === 'es' 
               ? '500 años de historia custodiados en arcos coloniales y piedra ancestral.'
               : '500 years of history guarded within colonial archways and ancient stone.'}
           </p>
        </div>
      </div>
      
      <!-- Right: Staggered Content & Huge Typography -->
      <div class="space-y-12 animate-on-scroll" style="transition-delay: 0.2s;">
        
        <div class="space-y-4">
          <span class="tag-dash-title block text-secondary">
            {lang === 'es' ? 'PATRIMONIO & LEGADO' : 'HERITAGE & SOUL'}
          </span>
          <h2 class="font-display text-5xl sm:text-6xl lg:text-7xl leading-none text-white tracking-tight">
            {lang === 'es' ? 'UN REFUGIO VIVO' : 'A LIVING SANCTUARY'}
          </h2>
          <p class="text-lg text-text-secondary-dark font-body font-light leading-relaxed pt-6">
            {lang === 'es'
              ? 'Ubicado a pasos del histórico Mercado de San Pedro, nuestro hotel ofrece un oasis de lujo sereno. Cada muro cuenta una historia de misticismo andino y calidez humana, diseñado para que descanses antes o después de Machu Picchu.'
              : 'Located steps from the historic San Pedro Market, our hotel offers an oasis of serene luxury. Every wall tells a story of Andean mysticism and human warmth, designed for you to rest before or after Machu Picchu.'}
          </p>
        </div>

        <!-- Metric Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-10 pt-10 border-t border-white/10">
          {stats.map((stat) => (
            <div class="space-y-1">
              <span class="font-display text-5xl sm:text-6xl font-bold text-secondary block">{stat.value}</span>
              <span class="text-[10px] font-mono uppercase tracking-widest text-text-secondary-dark font-semibold">
                {stat.label[lang]}
              </span>
            </div>
          ))}
        </div>

        <!-- Secondary Floating Image -->
        <div class="relative w-full h-64 sm:h-80 rounded-2xl overflow-hidden shadow-xl img-hover-zoom hidden sm:block">
           <Image
            src={pasilloImg}
            alt="Pasillos de Piedra USGAR Hotels"
            width={800}
            height={500}
            format="webp"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

      </div>

    </div>
  </div>
</section>
