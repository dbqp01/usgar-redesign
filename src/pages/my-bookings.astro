---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';

export const prerender = true;

const lang = (Astro.currentLocale || 'en') as 'en' | 'es';
const t = useTranslations(lang);
---

<Layout title={`${t('auth.myBookings')} — USGAR Hotels`} lang={lang}>
  <main class="py-28 px-4 max-w-5xl mx-auto flex-1 animate-fade-in space-y-8">
    
    <!-- Header -->
    <div class="bg-surface-card-light dark:bg-surface-card-dark p-8 md:p-10 rounded-3xl border border-black/10 dark:border-white/10 shadow-sm flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div class="space-y-2">
        <span class="text-xs font-semibold text-primary dark:text-purple-pastel uppercase tracking-widest">
          {t('auth.welcomeBack')}
        </span>
        <h1 id="user-greeting" class="font-display text-3xl md:text-4xl font-bold">
          {t('auth.bookingHistory')}
        </h1>
        <p id="user-email-display" class="text-text-secondary-light dark:text-text-secondary-dark text-sm">
          {t('auth.welcomeSubtitle')}
        </p>
      </div>

      <button
        id="logout-btn"
        type="button"
        class="hidden px-5 py-2.5 rounded-full border border-black/10 dark:border-white/10 hover:border-red-500 hover:text-red-500 text-sm font-medium transition-all duration-300 cursor-pointer"
      >
        {t('auth.signOut')}
      </button>
    </div>

    <!-- Alert / Loading Container -->
    <div id="bookings-loading" class="text-center py-12">
      <div class="inline-block w-8 h-8 border-4 border-primary border-t-transparent rounded-full animate-spin"></div>
      <p class="mt-4 text-sm text-text-secondary-light dark:text-text-secondary-dark font-medium">
        Loading your reservations...
      </p>
    </div>

    <div id="unauth-alert" class="hidden text-center py-16 bg-surface-card-light dark:bg-surface-card-dark p-8 rounded-3xl border border-black/10 dark:border-white/10 space-y-4">
      <svg class="w-12 h-12 text-stone-400 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
      </svg>
      <p class="text-base font-semibold">{t('auth.loginRequired')}</p>
      <a
        href={`/login?redirect=${encodeURIComponent(Astro.url.pathname)}`}
        class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-3 rounded-full text-sm transition-all"
      >
        {t('auth.signIn')}
      </a>
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-16 bg-surface-card-light dark:bg-surface-card-dark p-8 rounded-3xl border border-black/10 dark:border-white/10 space-y-4">
      <svg class="w-12 h-12 text-stone-400 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
      </svg>
      <p class="text-base font-semibold">{t('auth.noBookingsYet')}</p>
      <a
        href="/book"
        class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-3 rounded-full text-sm transition-all shadow-md"
      >
        {t('auth.startBooking')}
      </a>
    </div>

    <!-- Bookings List -->
    <div id="bookings-list" class="space-y-4 hidden"></div>

  </main>

  <script is:inline>
    (function() {
      async function initMyBookings() {
        const loadingEl = document.getElementById('bookings-loading');
        const unauthEl = document.getElementById('unauth-alert');
        const emptyEl = document.getElementById('empty-state');
        const listEl = document.getElementById('bookings-list');
        const greetingEl = document.getElementById('user-greeting');
        const emailEl = document.getElementById('user-email-display');
        const logoutBtn = document.getElementById('logout-btn');

        try {
          // Check user session
          const userRes = await fetch('/api/auth/me', { credentials: 'include' });
          if (!userRes.ok) throw new Error('Unauthenticated');

          const userData = await userRes.json();
          if (!userData.success || !userData.user) throw new Error('Unauthenticated');

          const user = userData.user;
          if (greetingEl) greetingEl.textContent = user.name ? `Hello, ${user.name}` : 'My Bookings';
          if (emailEl) emailEl.textContent = user.email;
          if (logoutBtn) {
            logoutBtn.classList.remove('hidden');
            logoutBtn.addEventListener('click', async () => {
              sessionStorage.removeItem('usgar_auth_user');
              await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
              window.location.href = '/';
            });
          }

          // Fetch bookings
          const bookingsRes = await fetch('/api/user/bookings', { credentials: 'include' });
          if (loadingEl) loadingEl.classList.add('hidden');

          if (!bookingsRes.ok) {
            if (emptyEl) emptyEl.classList.remove('hidden');
            return;
          }

          const bookingsData = await bookingsRes.json();
          const bookings = bookingsData.bookings || [];

          if (bookings.length === 0) {
            if (emptyEl) emptyEl.classList.remove('hidden');
            return;
          }

          // Render bookings
          if (listEl) {
            listEl.classList.remove('hidden');
            listEl.innerHTML = bookings.map(b => {
              const statusClass = b.status === 'confirmed' || b.status === 'paid'
                ? 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border-emerald-500/20'
                : b.status === 'pending'
                ? 'bg-amber-500/10 text-amber-600 dark:text-amber-400 border-amber-500/20'
                : 'bg-stone-500/10 text-stone-600 dark:text-stone-400 border-stone-500/20';

              const roomName = b.room_data?.name?.en || b.room_data?.name || b.id_room_type || 'Hotel Room';

              return `
                <div class="bg-surface-card-light dark:bg-surface-card-dark p-6 rounded-2xl border border-black/10 dark:border-white/10 shadow-sm flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
                  <div class="space-y-1">
                    <div class="flex items-center gap-3">
                      <h3 class="font-display font-bold text-lg">${roomName}</h3>
                      <span class="text-xs px-2.5 py-1 rounded-full font-semibold uppercase border ${statusClass}">
                        ${b.status}
                      </span>
                    </div>
                    <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark">
                      📅 ${b.checkin} → ${b.checkout}
                    </p>
                    <p class="text-xs font-mono text-stone-400">
                      Cart ID: ${b.cart_id} ${b.qlo_order_id ? '| Order: ' + b.qlo_order_id : ''}
                    </p>
                  </div>
                  <div class="text-left md:text-right">
                    <span class="text-xs text-text-secondary-light dark:text-text-secondary-dark block">Total</span>
                    <span class="font-bold text-xl text-primary">$${Number(b.price_snapshot).toFixed(2)} USD</span>
                  </div>
                </div>
              `;
            }).join('');
          }

        } catch (err) {
          if (loadingEl) loadingEl.classList.add('hidden');
          if (unauthEl) unauthEl.classList.remove('hidden');
        }
      }

      initMyBookings();
    })();
  </script>
</Layout>
