---
import Layout from "../layouts/Layout.astro";
import { useTranslations } from "../i18n/utils";
import { Image } from "astro:assets";

const lang = (Astro.currentLocale || "en") as "en" | "es";
const t = useTranslations(lang);

// Dynamically import all images
const hotelImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/hotel/**/*.jpg",
);
const roomImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/rooms/**/*.jpg",
);

// Resolve promises
const hotelPhotos = await Promise.all(
  Object.entries(hotelImages).map(async ([path, resolver]) => {
    const meta = (await resolver()).default;
    return { src: meta.src, metadata: meta, category: "hotel", path };
  }),
);

const roomPhotos = await Promise.all(
  Object.entries(roomImages).map(async ([path, resolver]) => {
    const meta = (await resolver()).default;
    return { src: meta.src, metadata: meta, category: "rooms", path };
  }),
);

// Combine and sort photos
const allPhotos = [...hotelPhotos, ...roomPhotos].sort((a, b) =>
  a.path.localeCompare(b.path),
);
---

<Layout
  title={`${t("gallery.title")} — USGAR Hotels`}
  lang={lang}
>
  <main class="py-24 px-4 max-w-7xl mx-auto flex-1 animate-fade-in">
    <!-- Header -->
    <div class="text-center mb-12 max-w-2xl mx-auto mt-8">
      <span class="text-xs font-semibold text-primary dark:text-purple-pastel uppercase tracking-widest block mb-2">
        {lang === "es" ? "Instalaciones y Habitaciones" : "Facilities & Accommodations"}
      </span>
      <h1 class="font-display text-4xl md:text-6xl mb-4 leading-tight">
        {t("gallery.title")}
      </h1>
      <p class="text-text-secondary-light dark:text-text-secondary-dark text-base md:text-lg">
        {t("gallery.subtitle")}
      </p>
    </div>

    <!-- Category Filters -->
    <div class="flex flex-wrap justify-center gap-3 mb-10 border-b border-black/5 dark:border-white/5 pb-6">
      <button
        class="filter-btn active px-6 py-2.5 rounded-full text-sm font-semibold border-2 border-primary bg-primary text-white transition-all cursor-pointer shadow-sm hover:scale-105"
        data-filter="all"
      >
        {t("gallery.filterAll")}
      </button>
      <button
        class="filter-btn px-6 py-2.5 rounded-full text-sm font-semibold border-2 border-transparent text-text-secondary-light dark:text-text-secondary-dark hover:border-black/10 dark:hover:border-white/10 hover:text-primary dark:hover:text-secondary transition-all cursor-pointer hover:scale-105"
        data-filter="hotel"
      >
        {t("gallery.filterHotel")}
      </button>
      <button
        class="filter-btn px-6 py-2.5 rounded-full text-sm font-semibold border-2 border-transparent text-text-secondary-light dark:text-text-secondary-dark hover:border-black/10 dark:hover:border-white/10 hover:text-primary dark:hover:text-secondary transition-all cursor-pointer hover:scale-105"
        data-filter="rooms"
      >
        {t("gallery.filterRooms")}
      </button>
    </div>

    <!-- Photo Grid -->
    <div
      id="gallery-grid"
      class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-5"
      data-images={JSON.stringify(allPhotos.map((p) => p.src))}
    >
      {
        allPhotos.map((photo, index) => (
          <div
            class="gallery-item group relative aspect-[4/3] rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 cursor-pointer border border-black/5 dark:border-white/5"
            data-category={photo.category}
            data-index={index}
          >
            <Image
              src={photo.metadata}
              alt={`${t("gallery.title")} - ${index + 1}`}
              width={500}
              height={375}
              format="webp"
              quality={70}
              loading={index < 8 ? "eager" : "lazy"}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <!-- Overlay visual -->
            <div class="absolute inset-0 bg-black/10 group-hover:bg-black/35 transition-colors duration-300 flex items-center justify-center">
              <div class="opacity-0 group-hover:opacity-100 transition-all duration-300 scale-90 group-hover:scale-100 p-3 rounded-full bg-white/15 backdrop-blur-md border border-white/25 shadow-md">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7" />
                </svg>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Visor Modal (Lightbox) -->
    <div
      id="gallery-lightbox"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/95 backdrop-blur-md transition-all duration-300"
    >
      <!-- Close Button -->
      <button
        id="lightbox-close-btn"
        class="absolute top-6 right-6 w-12 h-12 rounded-full bg-white/10 hover:bg-primary text-white flex items-center justify-center border border-white/10 transition-all cursor-pointer z-50 hover:scale-105"
        aria-label="Close"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Navigation Arrows -->
      <button
        id="lightbox-prev-btn"
        class="absolute left-6 w-14 h-14 rounded-full bg-white/5 hover:bg-primary text-white flex items-center justify-center border border-white/10 transition-all cursor-pointer z-50 hover:scale-105"
        aria-label="Previous"
      >
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        id="lightbox-next-btn"
        class="absolute right-6 w-14 h-14 rounded-full bg-white/5 hover:bg-primary text-white flex items-center justify-center border border-white/10 transition-all cursor-pointer z-50 hover:scale-105"
        aria-label="Next"
      >
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <!-- Image Slide Container -->
      <div class="relative max-w-5xl max-h-[80vh] px-4 flex items-center justify-center">
        <img
          id="lightbox-img"
          src=""
          alt="Lightbox active"
          class="max-w-full max-h-[80vh] rounded-xl object-contain shadow-2xl transition-all duration-300 border border-white/5"
        />
        <!-- Counter overlay -->
        <div
          id="lightbox-counter"
          class="absolute -bottom-10 bg-white/10 backdrop-blur-md border border-white/10 px-4 py-1.5 rounded-full text-white text-xs font-semibold"
        >
          1 / 1
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  let activeIndex = 0;
  let activeFilteredIndexes: number[] = [];
  let imageUrls: string[] = [];
  let abortController = new AbortController();

  function initGallery() {
    abortController.abort();
    abortController = new AbortController();
    const signal = abortController.signal;

    const grid = document.getElementById("gallery-grid");
    const items = document.querySelectorAll(".gallery-item");
    const filters = document.querySelectorAll(".filter-btn");

    const lightbox = document.getElementById("gallery-lightbox");
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
    const closeBtn = document.getElementById("lightbox-close-btn");
    const prevBtn = document.getElementById("lightbox-prev-btn");
    const nextBtn = document.getElementById("lightbox-next-btn");
    const counter = document.getElementById("lightbox-counter");

    if (!grid || !lightbox || !lightboxImg) return;

    imageUrls = JSON.parse(grid.getAttribute("data-images") || "[]");

    // Apply Filter Function
    function applyFilter(filter: string) {
      activeFilteredIndexes = [];

      items.forEach((item, index) => {
        const category = item.getAttribute("data-category");
        if (filter === "all" || category === filter) {
          item.classList.remove("hidden");
          activeFilteredIndexes.push(index);
        } else {
          item.classList.add("hidden");
        }
      });

      // Update item visual order/indices for Lightbox navigation
      items.forEach((item) => {
        const itemIdxStr = item.getAttribute("data-index");
        if (itemIdxStr) {
          const index = parseInt(itemIdxStr, 10);
          const newIdx = activeFilteredIndexes.indexOf(index);
          item.setAttribute("data-filtered-index", newIdx.toString());
        }
      });
    }

    // Initialize Default State
    applyFilter("all");

    // Click Filters
    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        filters.forEach((b) => {
          b.classList.remove("active", "bg-primary", "text-white", "border-primary");
          b.classList.add("border-transparent", "text-text-secondary-light", "dark:text-text-secondary-dark");
        });
        btn.classList.add("active", "bg-primary", "text-white", "border-primary");
        btn.classList.remove("border-transparent", "text-text-secondary-light", "dark:text-text-secondary-dark");

        const filter = btn.getAttribute("data-filter") || "all";
        applyFilter(filter);
      }, { signal });
    });

    // Lightbox Logic
    function updateLightbox() {
      if (!lightboxImg || imageUrls.length === 0) return;
      const originalIdx = activeFilteredIndexes[activeIndex];
      const src = imageUrls[originalIdx];
      if (src) {
        lightboxImg.src = src;
      }
      if (counter) {
        counter.textContent = `${activeIndex + 1} / ${activeFilteredIndexes.length}`;
      }
    }

    function openLightbox(idx: number) {
      if (!lightbox) return;
      activeIndex = idx;
      updateLightbox();
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
      if (!lightbox) return;
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      document.body.style.overflow = "";
    }

    function nextSlide() {
      if (activeFilteredIndexes.length === 0) return;
      activeIndex = (activeIndex + 1) % activeFilteredIndexes.length;
      updateLightbox();
    }

    function prevSlide() {
      if (activeFilteredIndexes.length === 0) return;
      activeIndex = (activeIndex - 1 + activeFilteredIndexes.length) % activeFilteredIndexes.length;
      updateLightbox();
    }

    // Clicks on Grid Items
    items.forEach((item) => {
      item.addEventListener("click", () => {
        const filteredIdxStr = item.getAttribute("data-filtered-index");
        if (filteredIdxStr) {
          openLightbox(parseInt(filteredIdxStr, 10));
        }
      }, { signal });
    });

    closeBtn?.addEventListener("click", closeLightbox, { signal });
    nextBtn?.addEventListener("click", nextSlide, { signal });
    prevBtn?.addEventListener("click", prevSlide, { signal });

    // Keyboard Events
    document.addEventListener("keydown", (e: KeyboardEvent) => {
      if (!lightbox || lightbox.classList.contains("hidden")) return;
      if (e.key === "Escape") closeLightbox();
      else if (e.key === "ArrowRight") nextSlide();
      else if (e.key === "ArrowLeft") prevSlide();
    }, { signal });
  }

  document.addEventListener("astro:page-load", initGallery);
</script>
