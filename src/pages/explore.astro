---
import Layout from '../layouts/Layout.astro';
import { attractions } from '../data/attractions';
import { useTranslations, type Locale } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = (Astro.currentLocale || 'en') as Locale;
const t = useTranslations(lang);

// Unique categories in dataset
const categories = ['all', 'historical', 'nature', 'cultural', 'adventure'];

const categoryLabels: Record<string, { en: string; es: string; fr: string; pt: string }> = {
  all: { en: 'All', es: 'Todos', fr: 'Tous', pt: 'Todos' },
  historical: { en: 'Historical', es: 'Histórico', fr: 'Historique', pt: 'Histórico' },
  nature: { en: 'Nature', es: 'Naturaleza', fr: 'Nature', pt: 'Natureza' },
  cultural: { en: 'Cultural', es: 'Cultural', fr: 'Culturel', pt: 'Cultural' },
  adventure: { en: 'Adventure', es: 'Aventura', fr: 'Aventure', pt: 'Aventura' }
};


const categoryIcons: Record<string, string> = {
  all: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21" /><line x1="9" y1="3" x2="9" y2="18" /><line x1="15" y1="6" x2="15" y2="21" /></svg>`,
  historical: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M3 7h18M3 3h18M5 7v14M19 7v14M9 11v6M15 11v6" /></svg>`,
  nature: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 5 15H2L8 3z" /></svg>`,
  cultural: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" /><path d="M8 14s1.5 2 4 2 4-2 4-2" /><line x1="9" y1="9" x2="9.01" y2="9" /><line x1="15" y1="9" x2="15.01" y2="9" /></svg>`,
  adventure: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m2 17 6-6 4 4 8-8" /><path d="M14 7h6v6" /></svg>`
};

const attractionsSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": t('explore.schemaName'),
  "description": t('explore.schemaDescription'),
  "itemListElement": attractions.map((attraction, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "TouristAttraction",
      "name": attraction.name[lang],
      "description": attraction.description[lang],
      "distance": attraction.distance,
      "location": {
        "@type": "Place",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Cusco",
          "addressCountry": "PE"
        }
      }
    }
  }))
};
---

<Layout title={`${t('explore.title')} — USGAR Hotels`} lang={lang} schema={attractionsSchema}>
  <!-- Top Banner / Hero -->
  <section class="relative pt-32 pb-20 px-4 bg-gradient-to-b from-primary/10 via-transparent to-transparent overflow-hidden">
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h1 class="font-display text-4xl md:text-6xl mb-6 leading-tight text-text-primary-light dark:text-text-primary-dark">
        {t('explore.title')}
      </h1>
      <p class="text-lg md:text-xl text-text-secondary-light dark:text-text-secondary-dark max-w-2xl mx-auto font-body font-light leading-relaxed">
        {t('explore.description')}
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="pb-24 px-4 max-w-7xl mx-auto">
    
    <!-- Controls (Search + Filters) -->
    <div class="mb-12 flex flex-col md:flex-row gap-6 items-center justify-between bg-surface-card-light dark:bg-surface-card-dark border border-black/5 dark:border-white/5 p-6 rounded-3xl shadow-sm">
      
      <!-- Category Filters -->
      <div class="flex gap-2 overflow-x-auto w-full md:w-auto pb-2 md:pb-0 scrollbar-hide snap-x snap-mandatory">
        {categories.map((cat) => (
          <button
            class="flex items-center gap-2 px-4 py-2 rounded-full border text-sm font-medium transition-all duration-300 cursor-pointer whitespace-nowrap snap-center select-none bg-stone-50 dark:bg-stone-900/40 border-stone-200 dark:border-stone-800 text-text-secondary-light dark:text-text-secondary-dark hover:border-primary/50 dark:hover:border-primary/50 hover:text-primary dark:hover:text-secondary hover:scale-[1.02]"
            data-category-filter={cat}
          >
            <span class="flex items-center text-current" aria-hidden="true" set:html={categoryIcons[cat]}></span>
            <span>{categoryLabels[cat][lang]}</span>
          </button>
        ))}
      </div>

      <!-- Search Bar -->
      <div class="relative w-full md:w-80">
        <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-stone-400">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </span>
        <input
          type="text"
          id="explore-search"
          placeholder={t('explore.searchPlaceholder')}
          class="w-full pl-10 pr-4 py-2.5 rounded-full border border-stone-200 dark:border-stone-800 bg-stone-50 dark:bg-stone-900/40 text-stone-800 dark:text-stone-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all placeholder:text-stone-400"
          aria-label="Search attractions"
        />
      </div>
    </div>

    <!-- Attractions Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8" id="attractions-grid">
      {attractions.map((attraction, i) => (
        <a
          href={getRelativeLocaleUrl(lang, `explore/${attraction.id}`)}
          class="p-6 rounded-2xl bg-surface-card-light dark:bg-surface-card-dark border border-black/5 dark:border-white/5 shadow-sm hover:shadow-lg hover:border-primary/20 dark:hover:border-primary/20 transition-all duration-500 hover:-translate-y-1 group flex flex-col justify-between"
          data-category={attraction.category}
          data-name-en={attraction.name.en.toLowerCase()}
          data-name-es={attraction.name.es.toLowerCase()}
          data-name-fr={attraction.name.fr.toLowerCase()}
          data-name-pt={attraction.name.pt.toLowerCase()}
          data-desc-en={attraction.description.en.toLowerCase()}
          data-desc-es={attraction.description.es.toLowerCase()}
          data-desc-fr={attraction.description.fr.toLowerCase()}
          data-desc-pt={attraction.description.pt.toLowerCase()}
          style={`transition-delay: ${i * 0.05}s`}
        >
          <div>
            <!-- Top badge row -->
            <div class="flex items-center justify-between mb-4">
              <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider bg-tertiary/10 text-tertiary">
                <span class="flex items-center text-current" aria-hidden="true" set:html={categoryIcons[attraction.category]}></span>
                <span>{categoryLabels[attraction.category][lang]}</span>
              </span>
              <span class="text-xs font-medium text-stone-500 dark:text-stone-400 bg-stone-100 dark:bg-stone-900 px-2.5 py-1 rounded-md flex items-center gap-1">
                <svg class="w-3 h-3 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {attraction.distance}
              </span>
            </div>

            <!-- Title & Desc -->
            <h3 class="font-display text-xl mb-3 text-text-primary-light dark:text-text-primary-dark group-hover:text-primary transition-colors duration-300">
              {attraction.name[lang]}
            </h3>
            <p class="text-sm md:text-base text-text-secondary-light dark:text-text-secondary-dark font-body leading-relaxed mb-6">
              {attraction.description[lang]}
            </p>
          </div>

          <!-- Bottom Time & Action Row -->
          <div class="pt-4 border-t border-black/5 dark:border-white/5 flex items-center justify-between text-xs text-text-secondary-dark font-body">
            <span class="flex items-center gap-1 font-medium">
              <svg class="w-3.5 h-3.5 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {attraction.travelTime}
            </span>
            <span class="text-primary hover:text-primary-dark font-semibold inline-flex items-center gap-0.5 group-hover:translate-x-0.5 transition-transform duration-300">
              {t('explore.viewGuide')}
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Empty State -->
    <div id="explore-empty-state" class="hidden text-center py-20 bg-surface-card-light dark:bg-surface-card-dark border border-black/5 dark:border-white/5 p-8 rounded-3xl mt-6">
      <svg class="w-12 h-12 mx-auto mb-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <h3 class="font-display text-2xl mb-2 text-text-primary-light dark:text-text-primary-dark">
        {t('explore.noResults')}
      </h3>
      <p class="text-text-secondary-light dark:text-text-secondary-dark font-body max-w-sm mx-auto">
        {t('explore.noResultsHint')}
      </p>
    </div>
  </section>
</Layout>

<script>
  let abortController = new AbortController();

  function initExploreFilters() {
    // Abort previous listeners to avoid duplicates
    abortController.abort();
    abortController = new AbortController();
    const signal = abortController.signal;

    const searchInput = document.getElementById('explore-search') as HTMLInputElement;
    const filterButtons = document.querySelectorAll('[data-category-filter]');
    const grid = document.getElementById('attractions-grid');
    const emptyState = document.getElementById('explore-empty-state');
    
    if (!grid || !emptyState) return;

    const cards = Array.from(grid.children) as HTMLElement[];
    const lang = document.documentElement.lang || 'en';

    let activeFilter = 'all';
    let searchQuery = '';

    // Set 'all' filter as active initially
    filterButtons.forEach(btn => {
      const cat = btn.getAttribute('data-category-filter');
      if (cat === 'all') {
        btn.classList.add('border-primary', 'text-primary', 'bg-primary/5');
        btn.classList.remove('border-stone-200', 'dark:border-stone-800', 'text-stone-600', 'dark:text-stone-400');
      }
    });

    function applyFilter() {
      let visibleCount = 0;

      cards.forEach(card => {
        const category = card.getAttribute('data-category');
        const nameAttr = `data-name-${lang}`;
        const descAttr = `data-desc-${lang}`;
        const name = card.getAttribute(nameAttr) || card.getAttribute('data-name-en') || '';
        const desc = card.getAttribute(descAttr) || card.getAttribute('data-desc-en') || '';

        const matchesCategory = activeFilter === 'all' || category === activeFilter;
        const matchesSearch = name.includes(searchQuery) || desc.includes(searchQuery);

        if (matchesCategory && matchesSearch) {
          card.classList.remove('hidden');
          // Add entrance animation class
          card.classList.add('animate-fade-in');
          visibleCount++;
        } else {
          card.classList.add('hidden');
          card.classList.remove('animate-fade-in');
        }
      });

      // Show/hide empty state
      if (visibleCount === 0) {
        emptyState!.classList.remove('hidden');
        grid!.classList.add('hidden');
      } else {
        emptyState!.classList.add('hidden');
        grid!.classList.remove('hidden');
      }
    }

    // Category button click
    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.getAttribute('data-category-filter') || 'all';
        activeFilter = cat;

        // Toggle button styling
        filterButtons.forEach(b => {
          if (b === btn) {
            b.classList.add('border-primary', 'text-primary', 'bg-primary/5');
            b.classList.remove('border-stone-200', 'dark:border-stone-800', 'text-stone-600', 'dark:text-stone-400');
          } else {
            b.classList.remove('border-primary', 'text-primary', 'bg-primary/5');
            b.classList.add('border-stone-200', 'dark:border-stone-800', 'text-stone-600', 'dark:text-stone-400');
          }
        });

        applyFilter();
      }, { signal });
    });

    // Search input typing
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
        applyFilter();
      }, { signal });
    }
  }

  document.addEventListener('astro:page-load', initExploreFilters);
</script>
