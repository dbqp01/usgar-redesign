{
  "name": "usgar-hotels",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "dev:php": "php -S localhost:8000 public/index.php",
    "dev:all": "node scripts/dev.js",
    "build": "astro build",
    "postbuild": "node -e \"import fs from 'fs'; fs.cpSync('app', 'dist/app', { recursive: true }); console.log(' Copied app/ to dist/app/ for Hostinger PHP APIs');\"",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "test:php": "php scripts/run-exhaustive-tests.php",
    "test": "astro check && php scripts/run-exhaustive-tests.php",
    "audit:security": "php scripts/audit-security.php",
    "audit:seo": "node scripts/audit-seo-schema.js",
    "audit:all": "npm run check && npm run test:php && npm run audit:security && npm run audit:seo",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.1",
    "leaflet": "^1.9.4",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  },
  "allowScripts": {
    "sharp@0.35.3": true,
    "esbuild@0.28.1": true
  }
}
