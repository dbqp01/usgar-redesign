RewriteEngine On

# Rewrite for /api/channex/booking/[id] -> /api/channex/booking-detail.php?id=[id]
RewriteRule ^api/channex/booking/([^/]+)$ api/channex/booking-detail.php?id=$1 [L,QSA]

# Rewrite for /api/channex/booking -> /api/channex/booking.php
RewriteRule ^api/channex/booking$ api/channex/booking.php [L,QSA]

# Rewrite for /api/channex/availability -> /api/channex/availability.php
RewriteRule ^api/channex/availability$ api/channex/availability.php [L,QSA]

# Rewrite for other /api/* -> /api/*.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/([^/]+)$ api/$1.php [L,QSA]
