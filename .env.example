# Configuración general
SITE_URL=http://localhost:8000
ENVIRONMENT=development # development, production

# Orígenes CORS permitidos (separados por coma). En desarrollo: *
# En producción: https://cusco.hotelesusgar.com,https://hotelesusgar.com
ALLOWED_ORIGINS=*

# IPs de proxies confiables para X-Forwarded-For (separados por coma)
# Dejar vacío si no se usa proxy reverso. Ejemplo: 127.0.0.1,10.0.0.1
TRUSTED_PROXIES=

# Clave secreta para ejecutar cron jobs via HTTP (cambiar en producción)
CRON_SECRET=cambiar_este_valor_en_produccion

# Conexión a la Base de Datos (Hostinger / MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=usgar_db_user
DB_PASS=usgar_db_password
DB_NAME=usgar_qloapps_db

# Integración con QloApps (Motor de reservas / CMS)
QLOAPP_API_URL=https://cms.hotelesusgar.com/api
QLOAPP_API_KEY=YOUR_QLOAPP_WEB_SERVICE_API_KEY

# Pasarela de Pagos (Mercado Pago)
# Tokens válidos: APP_USR-... (Checkout Pro, Point, QR) o TEST-... (Checkout API, Bricks)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxx-xxxxxx-xxxxxx
MERCADO_PAGO_WEBHOOK_SECRET=YOUR_MERCADO_PAGO_WEBHOOK_SECRET_KEY

# Gestor de Canales (Channex API)
CHANNEX_API_URL=https://api.channex.io/api/v1
CHANNEX_API_KEY=YOUR_CHANNEX_API_KEY
CHANNEX_PROPERTY_ID=YOUR_CHANNEX_PROPERTY_ID
CHANNEX_RATE_PLAN_ID=YOUR_CHANNEX_RATE_PLAN_ID

# Mapeos de Habitaciones Channex (Relaciona slug local con UUID de Channex)
# Formato: CHANNEX_ROOM_[SLUG_EN_MAYUSCULAS_CON_GUION_BAJO]
CHANNEX_ROOM_MATRIMONIAL=xxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CHANNEX_ROOM_DOBLE_SUPERIOR=xxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CHANNEX_ROOM_TRIPLE_STANDAR=xxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CHANNEX_ROOM_FAMILIAR_SUPERIOR=xxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
